    height: 8px;
    border-radius: 9999px;
    background: var(--card-wash);
    box-shadow: 0 0 0 1px color-mix(in oklab, var(--color-ink) 14%, transparent);
  }
  .flash-card__artifacts {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 14px;
  }
  .flash-card__artifacts span {
    padding: 12px 14px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.48);
    box-shadow: inset 0 0 0 1px rgba(36, 36, 36, 0.08);
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    color: #6b6553;
  }
  [hidden] {
    display: none !important;
  }

  @media (max-width: 1023px) {
    .journey-scene {
      min-height: 500px;
    }
    .front-train {
      width: 190px;
      height: 205px;
      bottom: 86px;
    }
    .front-train__face {
      width: 180px;
      height: 144px;
    }
    .front-train__bumper {
      width: 210px;
    }
    .station-sign__title {
      font-size: 32px;
    }
    .station-building {
      width: 720px;
      transform: translateX(-50%) scale(0.72);
      transform-origin: 50% 100%;
      bottom: 104px;
    }
    .station-train {
      width: 760px;
      transform: translateX(-50%) scale(0.68);
      transform-origin: 50% 100%;
      bottom: 70px;
    }
    .rail-journey[data-state="station"] .station-train {
      animation: none;
      opacity: 1;
    }
    .station-stage {
      padding-top: 168px;
    }
    .station-sign {
      width: min(270px, calc(100% - 32px));
    }
    .station-sign__title {
      font-size: 26px;
    }
    .flash-card__content {
      grid-template-columns: 1fr;
    }
    .flash-card h2 {
      font-size: 36px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .front-train,
    .rail-journey[data-state="travelling"] .front-train,
    .side-train,
    .side-train__wheel,
    .rail-journey[data-state="travelling"] .steam,
    .rail-journey[data-state="travelling"] .side-travel,
    .rail-journey[data-state="travelling"] .travel-sun,
    .rail-journey[data-state="travelling"] .travel-moon,
    .rail-journey[data-state="travelling"] .travel-bird,
    .mountain,
    .side-track span,
    .tree,
    .plant,
    .tree::before,
    .plant::before,
    .plant::after,
    .station-sign,
    .flash-card-stage,
    .flash-card-stage[data-open] .flash-card:not([hidden]) {
      transition: none;
      animation: none;
    }
  }
</style>

<script>
  function wireRailJourney() {
    const root = document.querySelector<HTMLElement>("[data-rail-journey]");
    const next = document.querySelector<HTMLButtonElement>("[data-journey-next]");
    const status = document.querySelector<HTMLElement>("[data-journey-status]");
    const terminal = document.querySelector<HTMLElement>("[data-terminal-panel]");
    const signs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-station-sign]"));
    const mapStops = Array.from(document.querySelectorAll<HTMLElement>("[data-map-stop]"));
    const stage = document.querySelector<HTMLElement>("[data-card-stage]");
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-flash-card]"));
    if (!root || !next || !status || !terminal || !signs.length || !stage || !cards.length) return;
    if (root.dataset.wired === "1") return;
    root.dataset.wired = "1";
    const journeyRoot = root;
    const nextButton = next;
    const statusText = status;
    const terminalPanel = terminal;
    const cardStage = stage;

    let current = -1;

    function showStop(index: number) {
      current = index;
      journeyRoot.dataset.currentIndex = String(index);
      journeyRoot.dataset.state = "station";
      terminalPanel.hidden = true;
      signs.forEach((sign, i) => {
        sign.hidden = i !== index;
      });
      mapStops.forEach((stop, i) => {
        stop.classList.toggle("journey-map__stop--active", i === index);
      });
      const sign = signs[index];
      const title = sign?.querySelector(".station-sign__title")?.textContent ?? "this stop";
      statusText.textContent = `Now arriving at ${title}. Click the station sign for details.`;
      nextButton.textContent = index >= signs.length - 1 ? "Restart journey" : "Next stop";
    }

    function departTo(index: number) {
      journeyRoot.dataset.state = "travelling";
      signs.forEach((sign) => (sign.hidden = true));
      terminalPanel.hidden = true;
      nextButton.disabled = true;
      statusText.textContent = "Travelling to the next station...";
      window.setTimeout(() => {
        showStop(index);
        nextButton.disabled = false;
      }, 3000);
    }

    nextButton.addEventListener("click", () => {
      const nextIndex = current >= signs.length - 1 ? 0 : current + 1;
      departTo(nextIndex);
    });

    function openCard(id: string) {
      cards.forEach((card) => {
        card.hidden = card.dataset.expId !== id;
      });
      cardStage.setAttribute("data-open", "");
      cardStage.setAttribute("aria-hidden", "false");
    }

    function closeCard() {
      cardStage.removeAttribute("data-open");
      cardStage.setAttribute("aria-hidden", "true");
      window.setTimeout(() => {
        if (!cardStage.hasAttribute("data-open")) {
          cards.forEach((card) => (card.hidden = true));
        }
      }, 180);
    }

    signs.forEach((sign) => {
      sign.addEventListener("click", () => {
        if (sign.dataset.expId) openCard(sign.dataset.expId);
      });
    });
    cardStage.querySelectorAll<HTMLElement>("[data-card-close]").forEach((button) => {
      button.addEventListener("click", closeCard);
    });
    cardStage.addEventListener("click", (e) => {
      if (e.target === cardStage) closeCard();
    });
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && stage.hasAttribute("data-open")) closeCard();
    });
  }

  wireRailJourney();
  document.addEventListener("astro:page-load", wireRailJourney);
</script>
