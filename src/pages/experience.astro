---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/home/Sidebar.astro";
import CustomCursor from "../components/home/CustomCursor.astro";
import { withBase } from "../lib/paths";
import { getCurrentVisitor } from "../lib/visitor-server";

const visitor = await getCurrentVisitor(Astro);
const cursorColor = visitor?.color ?? "pink";

const experiences = [
  {
    id: "ltimindtree",
    logo: "LT",
    logoSrc: withBase("/images/experience/logos/ltimindtree.png"),
    startDate: "2021-08",
    title: "LTIMindtree",
    role: "Quality Assurance Engineer",
    period: "Aug 2021 - Aug 2023",
    team: "Quality engineering, reporting validation, and system testing teams.",
    color: "lti",
    setting: "Engineering quality floor, validation cycles, and release checkpoints.",
    summary:
      "Reduced production defects, strengthened data validation, and translated business requirements into reliable test coverage across multiple systems.",
    work: [
      "Reduced production defects across 3 releases by analyzing defect trends and implementing corrective actions.",
      "Validated 10,000+ data records during testing cycles to ensure reporting accuracy and downstream data integrity.",
      "Translated 100+ business requirements into test scenarios aligned with reporting, validation, and system performance needs.",
    ],
    artifacts: ["Defect analysis", "Data validation", "Test scenarios"],
  },
  {
    id: "vista",
    logo: "VR",
    logoSrc: withBase("/images/experience/logos/vista-research-services.jpg"),
    startDate: "2024-05",
    title: "Vista Research Services",
    role: "Project Manager - Business Strategy & Transformation",
    period: "May 2024 - Apr 2025",
    team: "Business strategy, transformation, reporting operations, and analyst enablement.",
    color: "vista",
    setting: "Strategy room, reporting desk, SQL pipelines, and KPI operating rhythms.",
    summary:
      "Led reporting automation, KPI frameworks, and data-driven transformation work across business strategy and operations.",
    work: [
      "Reduced reporting turnaround by 3 days by automating recurring reports using SQL pipelines and structured data workflows.",
      "Saved 400 analyst hours annually by streamlining data collection, validation, and reporting workflows.",
      "Built KPI tracking frameworks for 25 processes and generated forecasting insights from 10,000+ records.",
    ],
    artifacts: ["SQL reporting", "KPI frameworks", "Forecasting insights"],
  },
  {
    id: "marketmaker-ba",
    logo: "MM",
    logoSrc: withBase("/images/experience/logos/market-maker-cre.jpg"),
    startDate: "2024-08",
    title: "Market Maker CRE",
    role: "Business Analyst - Product Strategy & Operations",
    period: "Aug 2024 - Dec 2024",
    team: "Product strategy, operations, transaction reporting, and process analysis.",
    color: "marketmaker",
    setting: "Commercial real estate workflows, transaction data, and product operations.",
    summary:
      "Analyzed operational and transaction datasets to improve process visibility, reporting quality, and product decision-making.",
    work: [
      "Analyzed operational and transaction datasets to identify inefficiencies across 20 business processes and reporting workflows.",
      "Validated 5,000+ monthly transaction records for accuracy, consistency, and reporting reliability.",
      "Supported product strategy and operations teams with clean analysis for decision-making and workflow improvement.",
    ],
    artifacts: ["Transaction QA", "Process analysis", "Reporting workflows"],
  },
  {
    id: "marketmaker-po",
    logo: "MM",
    logoSrc: withBase("/images/experience/logos/market-maker-cre.jpg"),
    startDate: "2025-01",
    title: "Market Maker CRE",
    role: "Product Owner - Product Strategy & Operations",
    period: "Jan 2025 - Apr 2025",
    team: "Product operations, roadmap planning, stakeholder reporting, and analytics.",
    color: "marketmaker",
    setting: "Commercial real estate workflows, product modules, and stakeholder dashboards.",
    summary:
      "Owned product visibility, KPI tracking, and feature prioritization across product modules and stakeholder reporting workflows.",
    work: [
      "Improved product visibility by tracking 12 KPIs through Tableau dashboards used by 8 cross-functional stakeholders.",
      "Drove feature prioritization across 3 product modules using user behavior, engagement, and transaction datasets.",
      "Generated 20 ad hoc reports monthly supporting roadmap decisions, stakeholder requests, and product performance analysis.",
    ],
    artifacts: ["Tableau dashboards", "Feature prioritization", "KPI scorecards"],
  },
  {
    id: "salesforce",
    logo: "SF",
    logoSrc: withBase("/images/experience/logos/salesforce.jpg"),
    startDate: "2025-04",
    title: "Salesforce",
    role: "Senior Business Process Analyst, Revenue Operations",
    period: "Apr 2025 - Apr 2026",
    team: "Revenue operations, process governance, enablement, and global stakeholder groups.",
    color: "salesforce",
    setting: "Revenue operations cloud, global enablement, and governed workflow rollout.",
    summary:
      "Delivered cross-functional revenue operations initiatives, improved workflow governance, and enabled scalable process adoption across global teams.",
    work: [
      "Delivered 8+ cross-functional initiatives by managing project plans, tracking 50+ milestones, and coordinating 10+ stakeholders.",
      "Built KPI dashboards and weekly reports tracking 15+ metrics across risks, dependencies, deliverables, and project health.",
      "Consolidated 80 fragmented artifacts into 27 standardized assets and facilitated 25+ workshops for process alignment.",
      "Supported rollout readiness by training 50+ users and developing structured enablement materials.",
    ],
    artifacts: ["Revenue operations", "KPI dashboards", "Process governance", "Enablement"],
  },
].sort((a, b) => b.startDate.localeCompare(a.startDate));
---

<BaseLayout title="Experience - Aishwarya's Portfolio" description="Experience and selected work.">
  <div class="experience-root flex flex-col min-h-screen">
    <Sidebar
      active="experience"
      anon={!visitor}
      visitorCard={visitor
        ? {
            name: visitor.name,
            color: visitor.color,
            number: visitor.number,
            signature: visitor.signature,
          }
        : null}
    />

    <main class="experience-page flex-1 min-w-0">
      <section class="experience-shell" data-experience-tabs aria-label="Experience">
        <aside class="experience-nav" aria-label="Experience list">
          <div class="experience-nav__intro">
            <p>Experience</p>
            <h1>Professional chapters</h1>
          </div>

          <div class="experience-line" role="tablist" aria-label="Select an experience">
            {
              experiences.map((item, index) => (
                <button
                  type="button"
                  class:list={[
                    "experience-tab",
                    `experience-tab--${item.color}`,
                    index === 0 && "experience-tab--active",
                  ]}
                  id={`tab-${item.id}`}
                  role="tab"
                  aria-selected={index === 0 ? "true" : "false"}
                  aria-controls={`panel-${item.id}`}
                  data-experience-tab
                  data-target={item.id}
                >
                  <span class="experience-tab__logo logo-frame" aria-hidden="true">
                    <span>{item.logo}</span>
                    <img src={item.logoSrc} alt="" loading="lazy" decoding="async" />
                  </span>
                  <span class="experience-tab__pin" aria-hidden="true" />
                  <span class="experience-tab__copy">
                    <strong>{item.title}</strong>
                    <small>{item.period}</small>
                  </span>
                </button>
              ))
            }
          </div>
        </aside>

        <section class="experience-content" aria-live="polite">
          {
            experiences.map((item, index) => (
              <article
                class:list={[
                  "experience-panel",
                  `experience-panel--${item.color}`,
                  index === 0 && "experience-panel--active",
                ]}
                id={`panel-${item.id}`}
                role="tabpanel"
                aria-labelledby={`tab-${item.id}`}
                data-experience-panel
                data-panel={item.id}
                hidden={index !== 0}
              >
                <div class="panel-place" aria-hidden="true">
                  <span />
                  <span />
                  <span />
                </div>

                <header class="panel-header">
                  <div class="panel-header__logo logo-frame" aria-hidden="true">
                    <span>{item.logo}</span>
                    <img src={item.logoSrc} alt="" loading="lazy" decoding="async" />
                  </div>
                  <h2>{item.title}</h2>
                  <p>{item.period}</p>
                </header>

                <div class="panel-summary">
                  <p>{item.summary}</p>
                </div>

                <div class="panel-grid">
                  <section class="detail-block detail-block--role">
                    <p class="detail-block__label">My Role</p>
                    <h3>{item.role}</h3>
                    <p>
                      Placeholder for the expanded role story: ownership, day-to-day scope,
                      operating rhythm, tools used, and the type of decisions this role supported.
                    </p>
                  </section>

                  <section class="detail-block">
                    <p class="detail-block__label">My Team</p>
                    <p>{item.team}</p>
                    <p>
                      Placeholder for collaborators, cross-functional partners, reporting lines,
                      stakeholder groups, and how work moved across the team.
                    </p>
                  </section>

                  <section class="detail-block detail-block--wide">
                    <p class="detail-block__label">Impact</p>
                    <ul>
                      {item.work.map((line) => (
                        <li>{line}</li>
                      ))}
                    </ul>
                  </section>

                  <section class="detail-block">
                    <p class="detail-block__label">Artifacts</p>
                    <div class="artifact-list">
                      {item.artifacts.map((artifact) => (
                        <span>{artifact}</span>
                      ))}
                    </div>
                  </section>

                  <section class="detail-block">
                    <p class="detail-block__label">Next Content Slot</p>
                    <p>
                      {item.setting} Placeholder for tools, screenshots, process notes, dashboards,
                      case-study links, lessons learned, or a short reflection from this experience.
                    </p>
                  </section>
                </div>
              </article>
            ))
          }
        </section>
      </section>
    </main>
  </div>

  <CustomCursor color={cursorColor} />
</BaseLayout>

<style>
  .experience-root {
    height: 100vh;
    overflow: hidden;
  }

  .experience-page {
    height: 100%;
    min-height: 0;
    overflow: hidden;
    padding: 14px clamp(12px, 2vw, 24px) 18px;
    background:
      radial-gradient(circle at 88% 10%, rgba(190, 89, 105, 0.13), transparent 290px),
      radial-gradient(circle at 8% 92%, rgba(47, 143, 123, 0.13), transparent 320px),
      var(--color-bg);
  }

  .experience-shell {
    display: grid;
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
    align-items: start;
    gap: clamp(16px, 2.4vw, 30px);
    height: 100%;
    min-height: 0;
  }

  .experience-nav {
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 20px;
    height: 100%;
    min-height: 0;
    overflow: auto;
    padding: clamp(18px, 2vw, 26px);
    border-radius: var(--radius-md);
    background: var(--color-bg-light);
    box-shadow:
      inset 0 0 0 1px rgba(23, 41, 74, 0.08),
      0 18px 48px -40px rgba(23, 41, 74, 0.55);
  }

  .experience-nav__intro p,
  .detail-block__label,
  .panel-header p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    line-height: 1;
    text-transform: uppercase;
    color: var(--color-ink-mute);
  }

  .experience-nav__intro h1 {
    margin: 8px 0 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    font-weight: 300;
    line-height: 0.92;
    color: var(--color-ink);
  }

  .experience-line {
    position: relative;
    display: grid;
    align-content: start;
    gap: 10px;
    min-height: 0;
    padding: 2px 0;
  }

  .experience-line::before {
    content: "";
    position: absolute;
    left: 74px;
    top: 12px;
    bottom: 12px;
    width: 2px;
    border-radius: 999px;
    background: linear-gradient(180deg, transparent, rgba(23, 41, 74, 0.32), transparent);
  }

  .experience-tab {
    --tab-accent: var(--color-pink);
    appearance: none;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 56px 36px minmax(0, 1fr);
    align-items: center;
    width: 100%;
    min-height: 74px;
    padding: 9px 10px;
    border: 0;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-ink);
    text-align: left;
    cursor: pointer;
    transition:
      background var(--duration-fast) var(--ease-out-soft),
      transform var(--duration-fast) var(--ease-out-soft),
      box-shadow var(--duration-fast) var(--ease-out-soft);
  }

  .experience-tab:hover,
  .experience-tab:focus-visible {
    background: rgba(255, 255, 255, 0.64);
    transform: translateX(3px);
    outline: none;
  }

  .experience-tab--active {
    background: var(--color-bg-white);
    box-shadow:
      inset 0 0 0 1px rgba(23, 41, 74, 0.09),
      0 14px 26px -24px rgba(23, 41, 74, 0.8);
  }

  .experience-tab__logo,
  .panel-header__logo {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, color-mix(in oklab, var(--tab-accent) 32%, white), white);
    box-shadow: inset 0 0 0 1px rgba(23, 41, 74, 0.1);
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-ink);
  }

  .logo-frame span {
    grid-area: 1 / 1;
  }

  .logo-frame img {
    grid-area: 1 / 1;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 7px;
    background: rgba(255, 255, 255, 0.82);
  }

  .experience-tab__logo {
    width: 46px;
    height: 46px;
    font-size: 0.88rem;
  }

  .experience-tab__pin {
    justify-self: center;
    width: 14px;
    height: 14px;
    border: 2px solid var(--color-bg-light);
    border-radius: 999px;
    background: var(--tab-accent);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--tab-accent) 24%, transparent);
  }

  .experience-tab__copy {
    display: grid;
    gap: 6px;
    min-width: 0;
  }

  .experience-tab__copy strong {
    overflow: hidden;
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.15;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .experience-tab__copy small {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.1;
    color: var(--color-ink-mute);
  }

  .experience-content {
    min-width: 0;
    min-height: 0;
    height: 100%;
    overflow-y: auto;
    padding-right: 4px;
    scrollbar-color: color-mix(in oklab, var(--color-ink) 22%, transparent) transparent;
  }

  .experience-panel {
    --tab-accent: var(--color-pink);
    --panel-ink: var(--color-ink);
    position: relative;
    overflow: hidden;
    min-height: 100%;
    padding: clamp(18px, 3vw, 34px);
    border-radius: var(--radius-md);
    background:
      linear-gradient(135deg, color-mix(in oklab, var(--tab-accent) 13%, white), transparent 360px),
      var(--color-bg-light);
    box-shadow:
      inset 0 0 0 1px rgba(23, 41, 74, 0.08),
      0 24px 62px -48px rgba(23, 41, 74, 0.72);
  }

  .experience-panel > :not(.panel-place) {
    position: relative;
    z-index: 1;
  }

  .panel-place {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    opacity: 0.42;
  }

  .panel-place::before {
    content: "";
    position: absolute;
    right: clamp(18px, 4vw, 54px);
    bottom: clamp(18px, 5vw, 72px);
    width: min(42vw, 520px);
    height: min(32vw, 350px);
    border-bottom: 2px solid color-mix(in oklab, var(--tab-accent) 34%, transparent);
    background:
      linear-gradient(
        90deg,
        transparent 0 8%,
        color-mix(in oklab, var(--tab-accent) 18%, transparent) 8% 9%,
        transparent 9% 17%
      ),
      repeating-linear-gradient(
        90deg,
        transparent 0 30px,
        color-mix(in oklab, var(--tab-accent) 18%, transparent) 31px 32px
      ),
      repeating-linear-gradient(
        0deg,
        transparent 0 36px,
        color-mix(in oklab, var(--tab-accent) 14%, transparent) 37px 38px
      );
    clip-path: polygon(
      0 48%,
      10% 48%,
      10% 28%,
      18% 28%,
      18% 58%,
      26% 58%,
      26% 18%,
      38% 18%,
      38% 68%,
      48% 68%,
      48% 36%,
      58% 36%,
      58% 58%,
      68% 58%,
      68% 24%,
      82% 24%,
      82% 46%,
      100% 46%,
      100% 100%,
      0 100%
    );
  }

  .panel-place::after {
    content: "";
    position: absolute;
    right: -70px;
    top: 34px;
    width: min(32vw, 360px);
    height: min(32vw, 360px);
    border: 1px solid color-mix(in oklab, var(--tab-accent) 25%, transparent);
    border-radius: 999px;
    background:
      radial-gradient(
        circle at 35% 35%,
        color-mix(in oklab, var(--tab-accent) 20%, transparent),
        transparent 34%
      ),
      radial-gradient(
        circle at 62% 58%,
        color-mix(in oklab, white 45%, transparent),
        transparent 28%
      );
  }

  .panel-place span {
    position: absolute;
    left: clamp(18px, 4vw, 58px);
    bottom: clamp(20px, 6vw, 82px);
    width: min(24vw, 280px);
    height: min(18vw, 190px);
    border: 1px solid color-mix(in oklab, var(--tab-accent) 24%, transparent);
    border-radius: var(--radius-md);
    transform: rotate(-5deg);
  }

  .panel-place span:nth-child(2) {
    left: auto;
    right: 24%;
    bottom: auto;
    top: 24%;
    width: min(18vw, 210px);
    height: min(11vw, 130px);
    transform: rotate(8deg);
  }

  .panel-place span:nth-child(3) {
    left: 32%;
    bottom: 10%;
    width: min(14vw, 160px);
    height: min(14vw, 160px);
    border-radius: 999px;
    transform: none;
  }

  .experience-panel--active {
    animation: panel-in 220ms var(--ease-out-soft);
  }

  @keyframes panel-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .panel-header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 18px;
    padding-bottom: clamp(18px, 3vw, 30px);
    border-bottom: 1px solid rgba(23, 41, 74, 0.1);
  }

  .panel-header__logo {
    width: clamp(62px, 8vw, 92px);
    height: clamp(62px, 8vw, 92px);
    font-size: clamp(1rem, 1.8vw, 1.35rem);
  }

  .panel-header h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5.8vw, 5.5rem);
    font-weight: 300;
    line-height: 0.92;
    text-align: center;
    color: var(--color-ink);
  }

  .panel-header p {
    justify-self: end;
    max-width: 16ch;
    text-align: right;
    color: var(--color-ink);
  }

  .panel-summary {
    max-width: 74ch;
    margin-top: clamp(18px, 2.6vw, 30px);
  }

  .panel-summary p,
  .detail-block p,
  .detail-block li {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--color-ink-dim);
  }

  .panel-summary p {
    font-size: clamp(1.05rem, 1.7vw, 1.28rem);
    color: var(--color-ink);
  }

  .panel-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(240px, 0.9fr);
    gap: 14px;
    margin-top: clamp(20px, 3vw, 36px);
  }

  .detail-block {
    display: grid;
    align-content: start;
    gap: 12px;
    min-width: 0;
    padding: 18px;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.56);
    box-shadow: inset 0 0 0 1px rgba(23, 41, 74, 0.08);
  }

  .detail-block--wide {
    grid-column: span 2;
  }

  .detail-block h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2.8vw, 2.5rem);
    font-weight: 300;
    line-height: 1;
    color: var(--color-ink)
    ;
  }

  .detail-block ul {
    display: grid;
    gap: 11px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .detail-block li {
    position: relative;
    padding-left: 20px;
  }

  .detail-block li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.68em;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--tab-accent);
  }

  .artifact-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .artifact-list span {
    padding: 9px 11px;
    border-radius: var(--radius-sm);
    background: color-mix(in oklab, var(--tab-accent) 16%, white);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .experience-tab--salesforce,
  .experience-panel--salesforce {
    --tab-accent: #2a8bdc;
  }

  .experience-tab--marketmaker,
  .experience-panel--marketmaker {
    --tab-accent: #2f8f58;
  }

  .experience-tab--vista,
  .experience-panel--vista {
    --tab-accent: #102b5a;
  }

  .experience-tab--lti,
  .experience-panel--lti {
    --tab-accent: #df7f1f;
  }

  .experience-panel--salesforce .panel-place::after {
    border-radius: 44% 56% 52% 48%;
    box-shadow:
      -120px 42px 0 -72px color-mix(in oklab, var(--tab-accent) 28%, transparent),
      -42px 88px 0 -58px color-mix(in oklab, white 64%, transparent);
  }

  .experience-panel--marketmaker .panel-place::before {
    clip-path: polygon(
      0 64%,
      8% 64%,
      8% 38%,
      15% 38%,
      15% 58%,
      24% 58%,
      24% 24%,
      34% 24%,
      34% 72%,
      43% 72%,
      43% 42%,
      52% 42%,
      52% 62%,
      62% 62%,
      62% 28%,
      72% 28%,
      72% 50%,
      84% 50%,
      84% 36%,
      100% 36%,
      100% 100%,
      0 100%
    );
  }

  .experience-panel--vista .panel-place {
    opacity: 0.34;
  }

  .experience-panel--vista .panel-place::before {
    clip-path: none;
    border: 0;
    background:
      repeating-linear-gradient(
        0deg,
        color-mix(in oklab, var(--tab-accent) 20%, transparent) 0 2px,
        transparent 2px 28px
      ),
      repeating-linear-gradient(
        90deg,
        color-mix(in oklab, var(--tab-accent) 18%, transparent) 0 2px,
        transparent 2px 38px
      );
  }

  .experience-panel--lti .panel-place::before {
    clip-path: polygon(
      0 52%,
      12% 52%,
      12% 32%,
      24% 32%,
      24% 62%,
      35% 62%,
      35% 22%,
      48% 22%,
      48% 70%,
      60% 70%,
      60% 40%,
      72% 40%,
      72% 58%,
      84% 58%,
      84% 30%,
      100% 30%,
      100% 100%,
      0 100%
    );
  }

  [hidden] {
    display: none !important;
  }

  @media (max-width: 980px) {
    .experience-shell {
      grid-template-columns: 1fr;
      height: auto;
      min-height: 0;
    }

    .experience-nav {
      height: auto;
      max-height: none;
      overflow: visible;
      gap: 14px;
    }

    .experience-line {
      overflow-x: auto;
      display: flex;
      gap: 10px;
      padding-bottom: 4px;
    }

    .experience-line::before {
      display: none;
    }

    .experience-tab {
      grid-template-columns: 44px minmax(0, 1fr);
      flex: 0 0 min(290px, 82vw);
      min-height: 68px;
    }

    .experience-tab__pin {
      display: none;
    }

    .panel-header {
      grid-template-columns: auto 1fr;
    }

    .panel-header h2 {
      text-align: left;
    }

    .panel-header p {
      grid-column: 1 / -1;
      justify-self: start;
      max-width: none;
      text-align: left;
    }
  }

  @media (max-width: 720px) {
    .experience-root {
      height: auto;
      min-height: 100vh;
      overflow: visible;
    }

    .experience-page {
      height: auto;
      overflow: visible;
    }

    .experience-page {
      padding-inline: 10px;
    }

    .experience-content {
      height: auto;
      overflow: visible;
      padding-right: 0;
    }

    .panel-grid {
      grid-template-columns: 1fr;
    }

    .detail-block--wide {
      grid-column: auto;
    }

    .experience-panel,
    .experience-nav {
      padding: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .experience-tab,
    .experience-panel--active {
      transition: none;
      animation: none;
    }
  }
</style>

<script>
  function wireExperienceTabs() {
    const root = document.querySelector<HTMLElement>("[data-experience-tabs]");
    if (!root || root.dataset.wired === "1") return;
    root.dataset.wired = "1";

    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-experience-tab]"));
    const panels = Array.from(root.querySelectorAll<HTMLElement>("[data-experience-panel]"));
    function selectExperience(id: string) {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.target === id;
        tab.classList.toggle("experience-tab--active", isActive);
        tab.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      panels.forEach((panel) => {
        const isActive = panel.dataset.panel === id;
        panel.hidden = !isActive;
        panel.classList.toggle("experience-panel--active", isActive);
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        if (tab.dataset.target) selectExperience(tab.dataset.target);
      });
    });
  }

  wireExperienceTabs();
  document.addEventListener("astro:page-load", wireExperienceTabs);
</script>
