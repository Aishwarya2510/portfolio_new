---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/home/Sidebar.astro";
import CustomCursor from "../components/home/CustomCursor.astro";
import { getCurrentVisitor } from "../lib/visitor-server";

const visitor = await getCurrentVisitor(Astro);
const cursorColor = visitor?.color ?? "pink";

const experiences = [
  {
    id: "ltimindtree",
    logo: "LT",
    stop: "Stop 01",
    platform: "Platform 2021",
    title: "LTIMindtree",
    role: "Quality Assurance Engineer",
    period: "Aug 2021 - Aug 2023",
    color: "teal",
    summary:
      "Reduced production defects, strengthened data validation, and translated business requirements into reliable test coverage across multiple systems.",
    work: [
      "Reduced production defects across 3 releases by analyzing defect trends and implementing corrective actions.",
      "Validated 10,000+ data records during testing cycles to ensure reporting accuracy and downstream data integrity.",
      "Translated 100+ business requirements into test scenarios aligned with reporting, validation, and system performance needs.",
    ],
    artifacts: ["Defect analysis", "Data validation", "Test scenarios"],
  },
  {
    id: "vista",
    logo: "VR",
    stop: "Stop 02",
    platform: "Platform 2024",
    title: "Vista Research Services",
    role: "Project Manager - Business Strategy & Transformation",
    period: "May 2024 - Apr 2025",
    color: "pink",
    summary:
      "Led reporting automation, KPI frameworks, and data-driven transformation work across business strategy and operations.",
    work: [
      "Reduced reporting turnaround by 3 days by automating recurring reports using SQL pipelines and structured data workflows.",
      "Saved 400 analyst hours annually by streamlining data collection, validation, and reporting workflows.",
      "Built KPI tracking frameworks for 25 processes and generated forecasting insights from 10,000+ records.",
    ],
    artifacts: ["SQL reporting", "KPI frameworks", "Forecasting insights"],
  },
  {
    id: "marketmaker-ba",
    logo: "MM",
    stop: "Stop 03",
    platform: "Platform 2024",
    title: "Market Maker CRE",
    role: "Business Analyst - Product Strategy & Operations",
    period: "Aug 2024 - Dec 2024",
    color: "orange",
    summary:
      "Analyzed operational and transaction datasets to improve process visibility, reporting quality, and product decision-making.",
    work: [
      "Analyzed operational and transaction datasets to identify inefficiencies across 20 business processes and reporting workflows.",
      "Validated 5,000+ monthly transaction records for accuracy, consistency, and reporting reliability.",
      "Supported product strategy and operations teams with clean analysis for decision-making and workflow improvement.",
    ],
    artifacts: ["Transaction QA", "Process analysis", "Reporting workflows"],
  },
  {
    id: "marketmaker-po",
    logo: "MM",
    stop: "Stop 04",
    platform: "Platform 2025",
    title: "Market Maker CRE",
    role: "Product Owner - Product Strategy & Operations",
    period: "Jan 2025 - Apr 2025",
    color: "teal",
    summary:
      "Owned product visibility, KPI tracking, and feature prioritization across product modules and stakeholder reporting workflows.",
    work: [
      "Improved product visibility by tracking 12 KPIs through Tableau dashboards used by 8 cross-functional stakeholders.",
      "Drove feature prioritization across 3 product modules using user behavior, engagement, and transaction datasets.",
      "Generated 20 ad hoc reports monthly supporting roadmap decisions, stakeholder requests, and product performance analysis.",
    ],
    artifacts: ["Tableau dashboards", "Feature prioritization", "KPI scorecards"],
  },
  {
    id: "salesforce",
    logo: "SF",
    stop: "Stop 05",
    platform: "Platform 2025",
    title: "Salesforce",
    role: "Senior Business Process Analyst, Revenue Operations",
    period: "Apr 2025 - Apr 2026",
    color: "pink",
    summary:
      "Delivered cross-functional revenue operations initiatives, improved workflow governance, and enabled scalable process adoption across global teams.",
    work: [
      "Delivered 8+ cross-functional initiatives by managing project plans, tracking 50+ milestones, and coordinating 10+ stakeholders.",
      "Built KPI dashboards and weekly reports tracking 15+ metrics across risks, dependencies, deliverables, and project health.",
      "Consolidated 80 fragmented artifacts into 27 standardized assets and facilitated 25+ workshops for process alignment.",
      "Supported rollout readiness by training 50+ users and developing structured enablement materials.",
    ],
    artifacts: ["Revenue operations", "KPI dashboards", "Process governance", "Enablement"],
  },
];
---

<BaseLayout title="Experience - Aishwarya's Portfolio" description="Experience and selected work.">
  <div class="flex flex-col min-h-screen">
    <Sidebar
      active="experience"
      anon={!visitor}
      visitorCard={visitor
        ? {
            name: visitor.name,
            color: visitor.color,
            number: visitor.number,
            signature: visitor.signature,
          }
        : null}
    />

    <main class="experience-page flex-1 min-w-0">
      <section
        class="rail-journey"
        data-rail-journey
        data-state="terminal"
        data-current-index="0"
        aria-label="Experience railway journey"
      >
        <header class="experience-hero">
          <p class="experience-hero__eyebrow">Experience Railway</p>
          <h1>Professional journey</h1>
          <p>
            Move stop by stop through the timeline, then click a station sign for the work,
            metrics, and impact from that chapter.
          </p>
        </header>

        <div class="journey-scene">
          <div class="station-illustration" aria-hidden="true">
            <span class="sun"></span>
            <span class="bird bird--a"></span>
            <span class="bird bird--b"></span>
            <div class="station-building">
              <span class="station-roof"></span>
              <span class="station-brick station-brick--a"></span>
              <span class="station-brick station-brick--b"></span>
              <span class="station-arch station-arch--left"></span>
              <span class="station-arch station-arch--center"></span>
              <span class="station-arch station-arch--right"></span>
              <span class="station-window station-window--left"></span>
              <span class="station-window station-window--right"></span>
              <span class="station-door"></span>
            </div>
          </div>

          <div class="track-perspective" aria-hidden="true">
            <span class="rail rail--left"></span>
            <span class="rail rail--right"></span>
            <span class="rail-sleeper rail-sleeper--a"></span>
            <span class="rail-sleeper rail-sleeper--b"></span>
            <span class="rail-sleeper rail-sleeper--c"></span>
            <span class="rail-sleeper rail-sleeper--d"></span>
          </div>

          <div class="front-train" data-front-train aria-hidden="true">
            <div class="front-train__chimney"></div>
            <div class="front-train__face">
              <span class="front-train__window front-train__window--left"></span>
              <span class="front-train__window front-train__window--right"></span>
              <span class="front-train__lamp"></span>
            </div>
            <div class="front-train__bumper"></div>
          </div>

          <div class="side-travel" aria-hidden="true">
            <div class="travel-sky">
              <span class="travel-sun"></span>
              <span class="travel-moon"></span>
              <span class="travel-bird travel-bird--a"></span>
              <span class="travel-bird travel-bird--b"></span>
              <span class="travel-bird travel-bird--c"></span>
              <span class="mountain mountain--a"></span>
              <span class="mountain mountain--b"></span>
              <span class="mountain mountain--c"></span>
            </div>
            <div class="steam steam--a"></div>
            <div class="steam steam--b"></div>
            <div class="steam steam--c"></div>
            <div class="passing-scenery">
              <span class="tree tree--a"></span>
              <span class="tree tree--b"></span>
              <span class="tree tree--c"></span>
              <span class="tree tree--d"></span>
              <span class="tree tree--e"></span>
              <span class="plant plant--a"></span>
              <span class="plant plant--b"></span>
              <span class="plant plant--c"></span>
            </div>
            <div class="side-train">
              <span class="side-train__chimney"></span>
              <span class="side-train__engine">
                <i></i><i></i>
              </span>
              <span class="side-train__car side-train__car--a">
                <i></i><i></i>
              </span>
              <span class="side-train__car side-train__car--b">
                <i></i><i></i>
              </span>
              <span class="side-train__wheel side-train__wheel--a"></span>
              <span class="side-train__wheel side-train__wheel--b"></span>
              <span class="side-train__wheel side-train__wheel--c"></span>
              <span class="side-train__wheel side-train__wheel--d"></span>
            </div>
            <div class="side-track">
              <span></span><span></span><span></span><span></span><span></span>
            </div>
          </div>

          <div class="station-stage">
            {
              experiences.map((item, index) => (
                <button
                  type="button"
                  class:list={["station-sign", `station-sign--${item.color}`]}
                  data-station-sign
                  data-exp-id={item.id}
                  data-index={index}
                  hidden={index !== 0}
                  aria-label={`Open ${item.title} experience`}
                >
                  <span class="station-sign__stop">{item.stop}</span>
                  <span class="station-sign__title">{item.title}</span>
                  <span class="station-sign__role">{item.role}</span>
                  <span class="station-sign__platform">{item.platform}</span>
                </button>
              ))
            }
          </div>

          <div class="station-train" aria-hidden="true">
            <span class="station-train__engine"></span>
            <span class="station-train__stack"></span>
            <span class="station-train__cab"></span>
            <span class="station-train__car station-train__car--a"></span>
            <span class="station-train__car station-train__car--b"></span>
            <span class="station-train__wheel station-train__wheel--a"></span>
            <span class="station-train__wheel station-train__wheel--b"></span>
            <span class="station-train__wheel station-train__wheel--c"></span>
            <span class="station-train__wheel station-train__wheel--d"></span>
          </div>

          <div class="journey-terminal" data-terminal-panel>
            <p>Terminal</p>
            <h2>Aishwarya's Professional Line</h2>
            <span>2021 - 2026</span>
          </div>
        </div>

        <div class="journey-controls">
          <button type="button" class="journey-button" data-journey-next>
            Start journey
          </button>
          <p data-journey-status>Waiting at the terminal.</p>
        </div>

        <div class="journey-map" aria-label="Journey stops">
          {
            experiences.map((item, index) => (
              <span
                class:list={["journey-map__stop", index === 0 && "journey-map__stop--active"]}
                data-map-stop
                data-index={index}
              >
                <span>{index + 1}</span>
                <strong>{item.title}</strong>
                <small>{item.period}</small>
              </span>
            ))
          }
        </div>

        <div class="flash-card-stage" data-card-stage aria-hidden="true">
          {
            experiences.map((item) => (
              <article
                class:list={["flash-card", `flash-card--${item.color}`]}
                data-flash-card
                data-exp-id={item.id}
                hidden
              >
                <button
                  type="button"
                  class="flash-card__close"
                  data-card-close
                  aria-label="Close experience card"
                >
                  x
                </button>
                <div class="flash-card__logo">{item.logo}</div>
                <p class="flash-card__period">{item.period}</p>
                <h2>{item.title}</h2>
                <p class="flash-card__role">{item.role}</p>
                <p class="flash-card__summary">{item.summary}</p>

                <div class="flash-card__content">
                  <section>
                    <h3>Work Done</h3>
                    <ul>
                      {item.work.map((line) => <li>{line}</li>)}
                    </ul>
                  </section>

                  <section>
                    <h3>Artifacts</h3>
                    <div class="flash-card__artifacts">
                      {item.artifacts.map((artifact) => <span>{artifact}</span>)}
                    </div>
                  </section>
                </div>
              </article>
            ))
          }
        </div>
      </section>
    </main>
  </div>

  <CustomCursor color={cursorColor} />
</BaseLayout>

<style>
  .experience-page {
    min-height: 0;
    padding: 12px clamp(12px, 2vw, 24px) 16px;
    background:
      radial-gradient(circle at 78% 18%, rgba(101, 182, 195, 0.16), transparent 280px),
      linear-gradient(180deg, rgba(255, 255, 255, 0.18), transparent 300px),
      var(--color-bg);
  }
  .experience-hero {
    max-width: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .experience-hero__eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }
  .experience-hero h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.35rem, 4vw, 4.2rem);
    font-weight: 300;
    line-height: 0.92;
    color: var(--color-ink);
  }
  .experience-hero p:not(.experience-hero__eyebrow) {
    margin: 0;
    max-width: 48ch;
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.35;
    color: var(--color-ink-dim);
  }
  .rail-journey {
    position: relative;
    display: grid;
    grid-template-columns: minmax(270px, 0.34fr) minmax(0, 1fr);
    grid-template-rows: auto auto 1fr;
    gap: 12px 18px;
    height: calc(100vh - 112px);
    min-height: 620px;
  }
  .journey-scene {
    grid-column: 2;
    grid-row: 1 / 4;
    position: relative;
    height: 100%;
    min-height: 0;
    border-radius: 12px;
    overflow: hidden;
    background:
      linear-gradient(180deg, #f29a1f 0%, #f8c95d 42%, #f4e3a7 68%, #c8b98f 68% 100%);
    box-shadow: inset 0 0 0 1px rgba(36, 36, 36, 0.08);
  }
  .journey-scene::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 0 62%, rgba(36, 36, 36, 0.06) 62% 100%),
      repeating-linear-gradient(90deg, transparent 0 42px, rgba(36, 36, 36, 0.035) 43px 44px);
    pointer-events: none;
  }
  .station-illustration {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 520ms var(--ease-out-soft);
  }
  .rail-journey[data-state="station"] .station-illustration {
    opacity: 1;
  }
  .sun {
    position: absolute;
    left: 28%;
    top: 28px;
    width: 164px;
    height: 164px;
    border-radius: 9999px;
    background: #ffe45e;
    box-shadow: 0 0 42px rgba(255, 228, 94, 0.5);
  }
  .bird {
    position: absolute;
    width: 34px;
    height: 14px;
    border-top: 3px solid rgba(255, 255, 255, 0.88);
    border-radius: 50%;
    transform: rotate(-8deg);
  }
  .bird::after {
    content: "";
    position: absolute;
    right: -18px;
    top: -3px;
    width: 34px;
    height: 14px;
    border-top: 3px solid rgba(255, 255, 255, 0.88);
    border-radius: 50%;
    transform: rotate(18deg);
  }
  .bird--a { right: 170px; top: 66px; }
  .bird--b { right: 88px; top: 46px; transform: scale(0.8) rotate(-8deg); }
  .station-building {
    position: absolute;
    left: 50%;
    bottom: 116px;
    width: min(760px, 82vw);
    height: 286px;
    transform: translateX(-50%);
    background:
      repeating-linear-gradient(0deg, transparent 0 13px, rgba(116, 67, 28, 0.16) 14px 15px),
      repeating-linear-gradient(90deg, #d4a06d 0 38px, #c88e59 39px 40px);
    border: 4px solid #7a3b1f;
    box-shadow: 0 18px 36px -26px rgba(36, 36, 36, 0.6);
  }
  .station-roof {
    position: absolute;
    left: -30px;
    right: -30px;
    top: -72px;
    height: 86px;
    background:
      repeating-linear-gradient(0deg, #4b2116 0 13px, #6e2e18 14px 18px);
    clip-path: polygon(3% 0, 97% 0, 100% 100%, 0 100%);
    box-shadow: 0 10px 0 rgba(45, 20, 15, 0.9);
  }
  .station-arch {
    position: absolute;
    bottom: 22px;
    width: 150px;
    height: 196px;
    border: 10px solid #8a3e25;
    border-radius: 90px 90px 8px 8px;
    background: #f1d8b3;
  }
  .station-arch--left { left: 58px; }
  .station-arch--center {
    left: 50%;
    width: 166px;
    transform: translateX(-50%);
  }
  .station-arch--right { right: 58px; }
  .station-window {
    position: absolute;
    bottom: 58px;
    width: 86px;
    height: 100px;
    border: 6px solid #7a3b1f;
    background:
      linear-gradient(90deg, transparent 47%, #15586a 48% 52%, transparent 53%),
      linear-gradient(0deg, transparent 47%, #15586a 48% 52%, transparent 53%),
      #7fd3e9;
    box-shadow: inset 0 0 0 5px rgba(255, 255, 255, 0.35);
    z-index: 2;
  }
  .station-window--left { left: 90px; }
  .station-window--right { right: 90px; }
  .station-door {
    position: absolute;
    left: 50%;
    bottom: 30px;
    width: 104px;
    height: 146px;
    border-radius: 70px 70px 4px 4px;
    background: #5a351d;
    transform: translateX(-50%);
    box-shadow: inset 0 0 0 10px rgba(255, 220, 150, 0.16);
    z-index: 2;
  }
  .station-brick {
    position: absolute;
    width: 44px;
    height: 22px;
    background:
      linear-gradient(90deg, #f0c094 0 45%, transparent 46% 54%, #f0c094 55%),
      #b97647;
    opacity: 0.9;
  }
  .station-brick--a { left: 28px; top: 52px; }
  .station-brick--b { right: 28px; top: 52px; }
  .track-perspective {
    position: absolute;
    left: 50%;
    bottom: -20px;
    width: min(76vw, 680px);
    height: 360px;
    transform: translateX(-50%);
    pointer-events: none;
    transition: opacity 360ms var(--ease-out-soft);
  }
  .rail-journey[data-state="travelling"] .track-perspective {
    opacity: 0;
  }
  .rail {
    position: absolute;
    bottom: 0;
    width: 7px;
    height: 100%;
    border-radius: 9999px;
    background: #6b6553;
    transform-origin: bottom;
  }
  .rail--left {
    left: 34%;
    transform: skewX(-19deg);
  }
  .rail--right {
    right: 34%;
    transform: skewX(19deg);
  }
  .rail-sleeper {
    position: absolute;
    left: 50%;
    height: 9px;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--color-ink) 34%, transparent);
    transform: translateX(-50%);
  }
  .rail-sleeper--a { bottom: 26px; width: 440px; }
  .rail-sleeper--b { bottom: 98px; width: 300px; }
  .rail-sleeper--c { bottom: 170px; width: 184px; }
  .rail-sleeper--d { bottom: 238px; width: 92px; }
  .front-train {
    position: absolute;
    left: 50%;
    bottom: 90px;
    width: 230px;
    height: 235px;
    transform: translateX(-50%);
    transition:
      transform 560ms var(--ease-out-soft),
      opacity 320ms var(--ease-out-soft);
    z-index: 5;
  }
  .rail-journey[data-state="travelling"] .front-train {
    animation: train-turn-side 420ms var(--ease-out-soft) forwards;
  }
  @keyframes train-turn-side {
    0% { transform: translateX(-50%) scale(1); opacity: 1; }
    100% { transform: translateX(-50%) scale(0.82) rotateY(70deg); opacity: 0; }
  }
  .front-train__chimney {
    position: absolute;
    left: 50%;
    top: 0;
    width: 42px;
    height: 42px;
    border-radius: 9px 9px 3px 3px;
    background: var(--color-ink);
    transform: translateX(-50%);
  }
  .front-train__face {
    position: absolute;
    left: 50%;
    top: 34px;
    width: 210px;
    height: 166px;
    border-radius: 42px 42px 24px 24px;
    background: var(--color-ink);
    transform: translateX(-50%);
    box-shadow:
      inset 0 -10px 0 rgba(255, 255, 255, 0.08),
      0 24px 36px -28px rgba(36, 36, 36, 0.7);
  }
  .front-train__window {
    position: absolute;
    top: 34px;
    width: 52px;
    height: 48px;
    border-radius: 16px;
    background: var(--color-bg-light);
  }
  .front-train__window--left { left: 38px; }
  .front-train__window--right { right: 38px; }
  .front-train__lamp {
    position: absolute;
    left: 50%;
    bottom: 38px;
    width: 34px;
    height: 34px;
    border-radius: 9999px;
    background: var(--color-orange-1);
    transform: translateX(-50%);
    box-shadow: 0 0 24px rgba(238, 188, 148, 0.75);
  }
  .front-train__bumper {
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 250px;
    height: 42px;
    border-radius: 18px;
    background: #6b6553;
    transform: translateX(-50%);
  }
  .side-travel {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    z-index: 6;
    transition: opacity 260ms var(--ease-out-soft);
    background: linear-gradient(180deg, #f7b548 0%, #f5d583 48%, #c8b98f 48% 100%);
  }
  .rail-journey[data-state="travelling"] .side-travel {
    opacity: 1;
    animation: travel-day-cycle 3s linear forwards;
  }
  @keyframes travel-day-cycle {
    0% {
      background: linear-gradient(180deg, #f7b548 0%, #f5d583 48%, #c8b98f 48% 100%);
    }
    45% {
      background: linear-gradient(180deg, #f29a1f 0%, #f6bb65 48%, #b7a77b 48% 100%);
    }
    72% {
      background: linear-gradient(180deg, #714f88 0%, #e08a61 48%, #8d8162 48% 100%);
    }
    100% {
      background: linear-gradient(180deg, #12182a 0%, #29334e 48%, #5f634e 48% 100%);
    }
  }
  .travel-sky {
    position: absolute;
    inset: 0 0 52% 0;
    overflow: hidden;
    pointer-events: none;
  }
  .travel-sun,
  .travel-moon {
    position: absolute;
    width: 88px;
    height: 88px;
    border-radius: 9999px;
    left: -110px;
    top: 54%;
  }
  .travel-sun {
    background: #ffe45e;
    box-shadow: 0 0 46px rgba(255, 228, 94, 0.6);
  }
  .rail-journey[data-state="travelling"] .travel-sun {
    animation: sun-arc 3s linear forwards;
  }
  .travel-moon {
    background: #e8edf8;
    box-shadow:
      inset -16px 0 0 #c8d0e0,
      0 0 34px rgba(232, 237, 248, 0.5);
    opacity: 0;
  }
  .rail-journey[data-state="travelling"] .travel-moon {
    animation: moon-arc 3s linear forwards;
  }
  @keyframes sun-arc {
    0% { opacity: 1; transform: translate(0, 34px); }
    42% { opacity: 1; transform: translate(48vw, -96px); }
    70% { opacity: 0.85; transform: translate(82vw, 18px); }
    100% { opacity: 0; transform: translate(110vw, 72px); }
  }
  @keyframes moon-arc {
    0%, 48% { opacity: 0; transform: translate(0, 64px); }
    58% { opacity: 1; transform: translate(16vw, 12px); }
    82% { opacity: 1; transform: translate(54vw, -76px); }
    100% { opacity: 0.95; transform: translate(98vw, 22px); }
  }
  .travel-bird {
    position: absolute;
    width: 32px;
    height: 13px;
    border-top: 3px solid rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    opacity: 0;
  }
  .travel-bird::after {
    content: "";
    position: absolute;
    right: -17px;
    top: -3px;
    width: 32px;
