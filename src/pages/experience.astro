<script>
  function wireExperienceTabs() {
    const root = document.querySelector<HTMLElement>("[data-experience-tabs]");
    if (!root || root.dataset.wired === "1") return;
    root.dataset.wired = "1";

    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-experience-tab]"));
    const panels = Array.from(root.querySelectorAll<HTMLElement>("[data-experience-panel]"));
    function scrollActivePanelToStart(panel: HTMLElement) {
      const siteNav = document.querySelector<HTMLElement>(".site-navbar");
      const chapterNav = root.querySelector<HTMLElement>(".experience-nav");
      const isMobile = window.matchMedia("(max-width: 980px)").matches;
      const offset =
        (isMobile ? (siteNav?.getBoundingClientRect().height ?? 0) + (chapterNav?.getBoundingClientRect().height ?? 0) : 0) +
        14;

      window.scrollTo({
        top: panel.getBoundingClientRect().top + window.scrollY - offset,
        behavior: window.matchMedia("(prefers-reduced-motion: reduce)").matches ? "auto" : "smooth",
      });
    }

    function selectExperience(id: string, shouldScroll = false) {
      let activePanel: HTMLElement | undefined;

      tabs.forEach((tab) => {
        const isActive = tab.dataset.target === id;
        tab.classList.toggle("experience-tab--active", isActive);
        tab.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      panels.forEach((panel) => {
        const isActive = panel.dataset.panel === id;
        panel.hidden = !isActive;
        panel.classList.toggle("experience-panel--active", isActive);
        if (isActive) activePanel = panel;
      });

      if (shouldScroll && activePanel) {
        requestAnimationFrame(() => scrollActivePanelToStart(activePanel));
      }
    }

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        if (tab.dataset.target) selectExperience(tab.dataset.target, true);
      });
    });
  }

  wireExperienceTabs();
  document.addEventListener("astro:page-load", wireExperienceTabs);
</script>
