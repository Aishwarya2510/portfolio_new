].sort((a, b) => b.startDate.localeCompare(a.startDate));
---

<BaseLayout title="Experience - Aishwarya's Portfolio" description="Experience and selected work." showPet={false}>
  <div class="experience-root flex flex-col min-h-screen">
    <Sidebar
      active="experience"
      anon={!visitor}
      visitorCard={visitor
        ? {
            name: visitor.name,
            color: visitor.color,
            number: visitor.number,
            signature: visitor.signature,
          }
        : null}
    />

    <main class="experience-page flex-1 min-w-0">
      <section class="experience-shell" data-experience-tabs aria-label="Experience">
        <aside class="experience-nav" aria-label="Experience list">
          <div class="experience-nav__intro">
            <p>Experience</p>
            <h1>Professional chapters</h1>
          </div>

          <div class="experience-line" role="tablist" aria-label="Select an experience">
            {
              experiences.map((item, index) => (
                <button
                  type="button"
                  class:list={[
                    "experience-tab",
                    `experience-tab--${item.color}`,
                    index === 0 && "experience-tab--active",
                  ]}
                  id={`tab-${item.id}`}
                  role="tab"
                  aria-selected={index === 0 ? "true" : "false"}
                  aria-controls={`panel-${item.id}`}
                  data-experience-tab
                  data-target={item.id}
                >
                  <span class="experience-tab__logo logo-frame" aria-hidden="true">
                    <span>{item.logo}</span>
                    <img src={item.logoSrc} alt="" loading="lazy" decoding="async" />
                  </span>
                  <span class="experience-tab__pin" aria-hidden="true" />
                  <span class="experience-tab__copy">
                    <strong>{item.title}</strong>
                    <small>{item.period}</small>
                  </span>
                </button>
              ))
            }
          </div>
        </aside>

        <section class="experience-content" aria-live="polite">
          {
            experiences.map((item, index) => (
              <article
                class:list={[
                  "experience-panel",
                  `experience-panel--${item.color}`,
                  index === 0 && "experience-panel--active",
                ]}
                id={`panel-${item.id}`}
                role="tabpanel"
                aria-labelledby={`tab-${item.id}`}
                data-experience-panel
                data-panel={item.id}
                hidden={index !== 0}
              >
                <div class="panel-place" aria-hidden="true">
                  <span />
                  <span />
                  <span />
                </div>

                <header class="panel-header">
                  <div class="panel-header__logo logo-frame" aria-hidden="true">
                    <span>{item.logo}</span>
                    <img src={item.logoSrc} alt="" loading="lazy" decoding="async" />
                  </div>
                  <h2>{item.title}</h2>
                  <p>{item.period}</p>
                </header>

                <div class="panel-summary">
                  <p>{item.summary}</p>
                </div>

                {item.caseStudy ? (
                  <div class="panel-grid panel-grid--case-study">
                    <section class="detail-block detail-block--role case-intro">
                      <p class="detail-block__label">Role Title</p>
                      <h3>{item.caseStudy.roleTitle}</h3>
                      <p>{item.caseStudy.slogan}</p>
                    </section>

                    <section class="detail-block case-card">
                      <p class="detail-block__label">The Friction</p>
                      <h3>Challenge</h3>
                      <p>{item.caseStudy.friction}</p>
                    </section>

                    <section class="detail-block detail-block--wide case-card">
                      <p class="detail-block__label">The Operational Play</p>
                      <h3>Strategy</h3>
                      <ul class="case-list">
                        {item.caseStudy.play.map((point) => (
                          <li>
                            <strong>{point.lead}:</strong> {point.text}
                          </li>
                        ))}
                      </ul>
                    </section>

                    <section class="case-leverage detail-block detail-block--wide">
                      <div class="case-leverage__copy">
                        <p class="detail-block__label">The Business Leverage</p>
                        <h3>Impact & Metrics</h3>
                        <ul class="case-list case-list--impact">
                          {item.caseStudy.leverage.map((point) => (
                            <li>
                              <strong>{point.lead}:</strong> {point.text}
                            </li>
                          ))}
                        </ul>
                      </div>

                      <aside class="metric-card" aria-label={`${item.caseStudy.metric.value} metric`}>
                        <strong>{item.caseStudy.metric.value}</strong>
                        <span>{item.caseStudy.metric.label}</span>
                      </aside>
                    </section>

                    {item.caseStudy.comparison && (
                      <section class="detail-block detail-block--wide comparison-block">
                        <p class="detail-block__label">As-Is vs. To-Be</p>
                        <h3>Process Evolution</h3>
                        <div class="comparison-table-wrap">
                          <table class="comparison-table">
                            <thead>
                              <tr>
                                <th>AS-IS (Before)</th>
                                <th>TO-BE (Modernized Process)</th>
                                <th>Tooling/Infrastructure</th>
                              </tr>
                            </thead>
                            <tbody>
                              {item.caseStudy.comparison.map((row) => (
                                <tr>
                                  <td>{row.before}</td>
                                  <td><strong>{row.after}</strong></td>
                                  <td>
                                    {row.tools.map((tool, toolIndex) => (
                                      <>
                                        <code>{tool}</code>{toolIndex < row.tools.length - 1 && " / "}
                                      </>
                                    ))}
                                  </td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      </section>
                    )}

                    <section class="detail-block">
                      <p class="detail-block__label">Proof Points</p>
                      <div class="artifact-list">
                        {item.artifacts.map((artifact) => (
                          <span>{artifact}</span>
                        ))}
                      </div>
                    </section>
                  </div>
                ) : null}
              </article>
            ))
          }
        </section>
      </section>
    </main>
  </div>

  <CustomCursor color={cursorColor} />
</BaseLayout>

<style>
  .experience-root {
    min-height: 100vh;
    overflow: visible;
  }

  .experience-page {
    height: auto;
    min-height: 0;
    overflow: visible;
    padding: 14px clamp(12px, 2vw, 24px) 18px;
    background:
      radial-gradient(circle at 88% 10%, rgba(190, 89, 105, 0.13), transparent 290px),
      radial-gradient(circle at 8% 92%, rgba(47, 143, 123, 0.13), transparent 320px),
      var(--color-bg);
  }

  .experience-shell {
    display: grid;
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
    align-items: start;
    gap: clamp(16px, 2.4vw, 30px);
    height: auto;
    min-height: 0;
  }

  .experience-nav {
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 20px;
    height: auto;
    min-height: 0;
    overflow: visible;
    padding: clamp(18px, 2vw, 26px);
    border-radius: var(--radius-md);
    background: var(--color-bg-light);
    box-shadow:
      inset 0 0 0 1px rgba(23, 41, 74, 0.08),
      0 18px 48px -40px rgba(23, 41, 74, 0.55);
  }

  .experience-nav__intro p,
  .detail-block__label,
  .panel-header p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    line-height: 1;
    text-transform: uppercase;
    color: var(--color-ink-mute);
  }

  .experience-nav__intro h1 {
    margin: 8px 0 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    font-weight: 300;
    line-height: 0.92;
    color: var(--color-ink);
  }

  .experience-line {
    position: relative;
    display: grid;
    align-content: start;
    gap: 10px;
    min-height: 0;
    padding: 2px 0;
  }

  .experience-line::before {
    content: "";
    position: absolute;
    left: 74px;
    top: 12px;
    bottom: 12px;
    width: 2px;
    border-radius: 999px;
    background: linear-gradient(180deg, transparent, rgba(23, 41, 74, 0.32), transparent);
  }

  .experience-tab {
    --tab-accent: var(--color-pink);
    appearance: none;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 56px 36px minmax(0, 1fr);
    align-items: center;
    width: 100%;
    min-height: 74px;
    padding: 9px 10px;
    border: 0;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-ink);
    text-align: left;
    cursor: pointer;
    transition:
      background var(--duration-fast) var(--ease-out-soft),
      transform var(--duration-fast) var(--ease-out-soft),
      box-shadow var(--duration-fast) var(--ease-out-soft);
  }

  .experience-tab:hover,
  .experience-tab:focus-visible {
    background: rgba(255, 255, 255, 0.64);
    transform: translateX(3px);
    outline: none;
  }

  .experience-tab--active {
    background: var(--color-bg-white);
    box-shadow:
      inset 0 0 0 1px rgba(23, 41, 74, 0.09),
      0 14px 26px -24px rgba(23, 41, 74, 0.8);
  }

  .experience-tab__logo,
  .panel-header__logo {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, color-mix(in oklab, var(--tab-accent) 32%, white), white);
    box-shadow: inset 0 0 0 1px rgba(23, 41, 74, 0.1);
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-ink);
  }

  .logo-frame span {
    grid-area: 1 / 1;
  }

  .logo-frame img {
    grid-area: 1 / 1;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 7px;
    background: rgba(255, 255, 255, 0.82);
  }

  .experience-tab__logo {
    width: 46px;
    height: 46px;
    font-size: 0.88rem;
  }

  .experience-tab__pin {
    justify-self: center;
    width: 14px;
    height: 14px;
    border: 2px solid var(--color-bg-light);
    border-radius: 999px;
    background: var(--tab-accent);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--tab-accent) 24%, transparent);
  }

  .experience-tab__copy {
    display: grid;
    gap: 6px;
    min-width: 0;
  }

  .experience-tab__copy strong {
    overflow: hidden;
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.15;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .experience-tab__copy small {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.1;
    color: var(--color-ink-mute);
  }

  .experience-content {
    min-width: 0;
    min-height: 0;
    height: auto;
    overflow: visible;
    padding-right: 4px;
    scrollbar-color: color-mix(in oklab, var(--color-ink) 22%, transparent) transparent;
  }

  .experience-panel {
    --tab-accent: var(--color-pink);
    --panel-ink: var(--color-ink);
    position: relative;
    overflow: hidden;
    min-height: 100%;
    padding: clamp(18px, 3vw, 34px);
    border-radius: var(--radius-md);
    background:
      linear-gradient(135deg, color-mix(in oklab, var(--tab-accent) 13%, white), transparent 360px),
      var(--color-bg-light);
    box-shadow:
      inset 0 0 0 1px rgba(23, 41, 74, 0.08),
      0 24px 62px -48px rgba(23, 41, 74, 0.72);
  }

  .experience-panel > :not(.panel-place) {
    position: relative;
    z-index: 1;
  }

  .panel-place {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    opacity: 0.42;
  }

  .panel-place::before {
    content: "";
    position: absolute;
    right: clamp(18px, 4vw, 54px);
    bottom: clamp(18px, 5vw, 72px);
    width: min(42vw, 520px);
    height: min(32vw, 350px);
    border-bottom: 2px solid color-mix(in oklab, var(--tab-accent) 34%, transparent);
    background:
      linear-gradient(
        90deg,
        transparent 0 8%,
        color-mix(in oklab, var(--tab-accent) 18%, transparent) 8% 9%,
        transparent 9% 17%
      ),
      repeating-linear-gradient(
        90deg,
        transparent 0 30px,
        color-mix(in oklab, var(--tab-accent) 18%, transparent) 31px 32px
      ),
      repeating-linear-gradient(
        0deg,
        transparent 0 36px,
        color-mix(in oklab, var(--tab-accent) 14%, transparent) 37px 38px
      );
    clip-path: polygon(
      0 48%,
      10% 48%,
      10% 28%,
      18% 28%,
      18% 58%,
      26% 58%,
      26% 18%,
