---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/home/Sidebar.astro";
import ProjectIndexCard from "../components/home/ProjectIndexCard.astro";
import CustomCursor from "../components/home/CustomCursor.astro";
import { withBase } from "../lib/paths";
---

<BaseLayout
  title="Aishwarya's Portfolio"
  description="Aishwarya's portfolio - AI strategy, product management, data quality, and technology management projects."
>
  <!--
    Wallet finale veil. Shares `transition:name="wallet-veil"` with the
    cream backdrop on the onboarding wallet overlay, so the cream persists
    across the ClientRouter nav from /onboarding → /home and then peels back
    here. If the visitor lands on /home directly (refresh, deep-link), the
    script below hides the veil immediately so the page reads normally.
  -->
  <div
    data-home-veil
    transition:name="wallet-veil"
    aria-hidden="true"
    class="home-veil fixed inset-0 z-50 bg-[var(--color-bg)] pointer-events-none"
  >
  </div>

  <div class="flex flex-col min-h-screen" data-home-shell>
    <Sidebar anon />

    <main class="home-main flex flex-col gap-3 p-3 sm:p-4 md:p-5 flex-1 min-w-0" data-home-main>
      <div class="work-board" data-home-stack>
        <section class="work-hero" aria-labelledby="work-title">
          <div class="work-hero__copy">
            <p class="work-hero__eyebrow">Projects</p>
            <h1 id="work-title">My work, shown as build stories.</h1>
          </div>

          <div class="work-hero__signals" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
        </section>

        <div class="work-grid">
          <ProjectIndexCard
            title="Agent Maestro"
            number={1}
            role="AI Operations Strategy"
            team="Independent concept"
            shipped="2026"
            status={["Decision Ops", "AI Governance"]}
            description="I built this from a simple question: what would it take to turn a messy operational request into a decision someone could trust, route, and audit?"
            accent="teal"
            image={withBase("/images/projects/agent-maestro/hero.png")}
            imageHeight={190}
            href={withBase("/work/agent-maestro/")}
            tilt={0}
          />
          <ProjectIndexCard
            title="AI ValueOps"
            number={2}
            role="AI Economics & Operations"
            team="Independent concept"
            shipped="2026"
            status={["AI Value", "Portfolio Ops"]}
            description="I treated AI spend like an operating problem, then designed the layers I would need to connect cost, ownership, workflow outcomes, and scale choices."
            accent="orange"
            image={withBase("/images/projects/ai-valueops/governance-layer.png")}
            imageHeight={190}
            href={withBase("/work/ai-valueops/")}
            tilt={0}
          />
          <ProjectIndexCard
            title="AI Pilot-to-Scale"
            number={3}
            role="Product Ops & GTM"
            team="Independent concept"
            shipped="2026"
            status={["Launch Readiness", "AI Scale"]}
            description="I mapped the awkward middle between a promising AI pilot and a real launch: evidence, readiness, blockers, owners, and the decision to scale or stop."
            accent="teal"
            image={withBase("/images/projects/ai-pilot-to-scale/ai-pilot.png")}
            imageHeight={190}
            href={withBase("/work/ai-pilot-to-scale/")}
            tilt={0}
          />
          <ProjectIndexCard
            title="AI Operating Discipline"
            slug="ai-operating-discipline"
            number={4}
            role="Enterprise AI Strategy"
            team="Portfolio case study"
            shipped="July 2026"
            status={["Case Study", "AI Governance"]}
            description="I turned a research-backed AI adoption problem into a workflow-first operating model for routing, ownership, review, and value measurement."
            accent="orange"
            imageHeight={190}
            href={withBase("/work/ai-operating-discipline/")}
            tilt={0}
          />
        </div>

        <section class="coming-banner" aria-label="More projects coming soon">
          <div class="coming-banner__track">
            <span>More build stories coming</span>
            <span>More build stories coming</span>
            <span>More build stories coming</span>
            <span>More build stories coming</span>
          </div>
        </section>

        <section class="project-sparks" aria-label="More projects coming">
          <div class="project-sparks__copy">
            <p>In progress</p>
            <h2>More thinking, fewer templates.</h2>
          </div>
          <div class="project-sparks__art" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
        </section>
      </div>
    </main>
  </div>

  <CustomCursor color="teal" />

  <style is:global>
    /*
      Inline site-preview chips — hovering "Lingofable" / "Skloňuj" inside the
      LatestLog surfaces a mini browser window with the site thumbnail.
    */
    .latest-log__site-link {
      position: relative;
      color: var(--color-ink-inverted);
      text-decoration: underline;
      text-underline-offset: 2px;
      text-decoration-thickness: 1px;
      text-decoration-color: color-mix(in oklab, var(--color-ink-inverted) 40%, transparent);
      transition: text-decoration-color var(--duration-fast) var(--ease-out-soft);
    }
    .latest-log__site-link:hover {
      text-decoration-color: var(--color-ink-inverted);
    }
    .latest-log__preview {
      position: fixed;
      top: 0;
      left: 0;
      width: 240px;
      padding: 8px;
      border-radius: 10px;
      background: var(--color-bg-light);
      border: 1px solid color-mix(in oklab, var(--color-ink) 10%, transparent);
      box-shadow:
        0 18px 36px -16px rgba(36, 36, 36, 0.55),
        0 4px 10px -4px rgba(36, 36, 36, 0.35);
      pointer-events: none;
      opacity: 0;
      transform: translate(var(--preview-x, 0px), calc(var(--preview-y, 0px) + 6px)) scale(0.97);
      transform-origin: bottom center;
      transition:
        opacity 200ms var(--ease-out-soft),
        transform 240ms var(--ease-out-soft);
      z-index: 50;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .latest-log__site-link:hover .latest-log__preview,
    .latest-log__site-link:focus-visible .latest-log__preview {
      opacity: 1;
      transform: translate(var(--preview-x, 0px), var(--preview-y, 0px)) scale(1);
    }
    .site-preview__chrome {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0 2px;
    }
    .site-preview__dots {
      display: inline-flex;
      gap: 3px;
    }
    .site-preview__dots i {
      display: block;
      width: 5px;
      height: 5px;
      border-radius: 9999px;
      background: color-mix(in oklab, var(--color-ink) 30%, transparent);
    }
    .site-preview__url {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.02em;
      text-transform: none;
      color: var(--color-ink-dim);
    }
    .site-preview__thumb {
      display: block;
      width: 100%;
      height: 120px;
      border-radius: 6px;
      background-size: cover;
      background-position: center top;
      background-color: var(--color-bg-neutral);
    }

    @media (prefers-reduced-motion: reduce) {
      .coming-banner__track {
        animation: none !important;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .latest-log__preview {
        transition: opacity 120ms var(--ease-out-soft);
        transform: translate(var(--preview-x, 0px), var(--preview-y, 0px));
      }
      .latest-log__site-link:hover .latest-log__preview {
        transform: translate(var(--preview-x, 0px), var(--preview-y, 0px));
      }
    }

    .work-board {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .work-hero {
      position: relative;
      overflow: hidden;
      border-radius: 12px;
      min-height: 118px;
      padding: 12px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
      gap: 14px;
      background:
        linear-gradient(135deg, rgba(255, 196, 87, 0.22), transparent 42%),
        linear-gradient(110deg, var(--color-bg-light), var(--color-bg-neutral));
      box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 10%, transparent);
    }
    .work-hero::before,
    .work-hero::after {
      content: "";
      position: absolute;
      pointer-events: none;
      opacity: 0.72;
    }
    .work-hero::before {
      right: 18%;
      top: -42px;
      width: 118px;
      height: 118px;
      border: 1px solid color-mix(in oklab, var(--color-orange) 42%, transparent);
      transform: rotate(18deg);
    }
    .work-hero::after {
      right: 28px;
      bottom: 18px;
      width: 190px;
      height: 58px;
      background:
        linear-gradient(
          90deg,
          transparent 0 18px,
          color-mix(in oklab, var(--color-orange) 46%, transparent) 18px 21px,
          transparent 21px 42px
        ),
        linear-gradient(color-mix(in oklab, var(--color-ink) 10%, transparent) 1px, transparent 1px);
      background-size:
        42px 100%,
        100% 14px;
      mask-image: linear-gradient(to left, black, transparent);
    }
    .work-hero__copy {
      position: relative;
      z-index: 1;
      max-width: 780px;
    }
    .work-hero__eyebrow {
      margin: 0 0 5px;
      font-family: var(--font-mono);
      font-size: 11px;
      line-height: 1;
      text-transform: uppercase;
      color: var(--color-ink-dim);
    }
    .work-hero h1 {
      margin: 0;
      max-width: 16ch;
      font-family: var(--font-display);
      font-size: clamp(28px, 3.2vw, 38px);
      line-height: 0.94;
      font-weight: 300;
      color: var(--color-ink);
    }
    .work-hero__copy p:last-child {
      margin: 7px 0 0;
      max-width: 64ch;
      font-family: var(--font-body);
      font-size: 12px;
      line-height: 1.28;
      color: #6b6553;
    }
    .work-hero__signals {
      position: relative;
      z-index: 1;
      width: min(280px, 34vw);
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6px;
    }
    .work-hero__signals span {
      position: relative;
      min-height: 46px;
      border-radius: 8px;
      overflow: hidden;
      background:
        linear-gradient(135deg, color-mix(in oklab, var(--color-bg) 86%, var(--color-orange-1)), white),
        var(--color-bg);
      box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 10%, transparent);
    }
    .work-hero__signals span::before,
    .work-hero__signals span::after {
      content: "";
      position: absolute;
      border-radius: 999px;
    }
    .work-hero__signals span::before {
      inset: 12px auto auto 12px;
      width: 28px;
      height: 6px;
      background: var(--color-teal);
    }
    .work-hero__signals span::after {
      right: 10px;
      bottom: 9px;
      width: 16px;
      height: 16px;
      background: var(--color-orange);
      box-shadow: -18px -12px 0 color-mix(in oklab, var(--color-pink) 78%, white);
    }
    .work-hero__signals span:nth-child(2)::before {
      width: 6px;
      height: 28px;
      background: var(--color-pink);
    }
    .work-hero__signals span:nth-child(3)::after {
      width: 24px;
      height: 24px;
      background: transparent;
      border: 2px solid var(--color-teal);
      box-shadow: none;
    }
    .work-hero__signals span:nth-child(4)::before {
      width: 42px;
      background: var(--color-orange);
    }

    .work-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: clamp(14px, 2vw, 22px);
      align-items: stretch;
    }

    .coming-project-card {
      position: relative;
      isolation: isolate;
      min-height: 100%;
      overflow: hidden;
      border-radius: 10px;
      padding: 12px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      background:
        linear-gradient(
          180deg,
          color-mix(in oklab, var(--color-orange) 14%, transparent),
          transparent 42%
        ),
        var(--color-bg-light);
      color: var(--color-ink);
      box-shadow:
        inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 8%, transparent),
        0 0 4px 0 rgba(124, 86, 48, 0.34);
    }

    .coming-project-card::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      background:
        linear-gradient(
          90deg,
          transparent 0 18px,
          color-mix(in oklab, var(--color-orange) 24%, transparent) 18px 20px,
          transparent 20px
        ),
        radial-gradient(
          circle at 82% 16%,
          color-mix(in oklab, var(--color-teal) 32%, transparent),
          transparent 30%
        );
      background-size: 38px 100%, auto;
      opacity: 0.42;
    }

    .coming-project-card__top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
    }

    .coming-project-card__hole {
      width: 13px;
      height: 13px;
      border-radius: 9999px;
      background: var(--color-bg);
      box-shadow:
        inset 0 1px 1.5px rgba(36, 36, 36, 0.35),
        inset 0 -0.5px 0.5px rgba(255, 255, 255, 0.4),
        0 0 0 1px color-mix(in oklab, var(--color-ink) 14%, transparent);
    }

    .coming-project-card__num {
      display: inline-grid;
      place-items: center;
      min-width: 48px;
      height: 24px;
      border-radius: 999px;
      background: color-mix(in oklab, var(--color-orange) 24%, var(--color-bg));
      box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 10%, transparent);
      font-family: var(--font-mono);
      font-size: 11px;
      line-height: 1;
      text-transform: uppercase;
      color: var(--color-ink);
    }

    .coming-project-card__stage {
      position: relative;
      min-height: 190px;
      overflow: hidden;
      border-radius: 8px;
      background:
        linear-gradient(135deg, color-mix(in oklab, var(--color-teal) 72%, #242424), #242424 74%);
      box-shadow:
        inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 8%, transparent),
        0 8px 18px -16px rgba(36, 36, 36, 0.52);
    }

    .coming-project-card__stage::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.1) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
      background-size: 18px 18px;
      mask-image: linear-gradient(to bottom, black, transparent 82%);
    }

    .coming-project-card__stage span {
      position: absolute;
      display: block;
      border-radius: 999px;
      background: color-mix(in oklab, var(--color-orange) 78%, white);
      box-shadow: 0 0 18px color-mix(in oklab, var(--color-orange) 50%, transparent);
    }

    .coming-project-card__stage span:nth-child(1) {
      left: 18px;
      bottom: 18px;
      width: 42px;
      height: 5px;
    }

    .coming-project-card__stage span:nth-child(2) {
      left: 74px;
      bottom: 28px;
      width: 68px;
      height: 5px;
    }

    .coming-project-card__stage span:nth-child(3) {
      right: 46px;
      top: 22px;
      width: 32px;
      height: 32px;
      background: transparent;
      border: 1px solid color-mix(in oklab, var(--color-bg-light) 68%, transparent);
      box-shadow: none;
    }

    .coming-project-card__stage span:nth-child(4) {
      right: 18px;
      bottom: 17px;
      width: 22px;
      height: 22px;
      background: var(--color-bg-light);
    }

    .coming-project-card__body {
      display: grid;
      gap: 5px;
      margin-top: 2px;
    }

    .coming-project-card__kicker {
      margin: 0;
      font-family: var(--font-mono);
      font-size: 11px;
      line-height: 1;
      text-transform: uppercase;
      color: var(--color-ink-dim);
    }

    .coming-project-card h3 {
      margin: 0;
      font-family: var(--font-display);
      font-weight: 300;
      font-size: clamp(1.85rem, 3vw, 2.75rem);
      line-height: 1;
      color: var(--color-ink);
    }

    .coming-project-card__body p:last-child {
      margin: 0;
      font-family: var(--font-body);
      font-size: 0.95rem;
      line-height: 1.38;
      color: #6b6553;
    }

    .coming-banner {
      overflow: hidden;
      border-radius: 10px;
      background: var(--color-ink);
      color: var(--color-bg-light);
      box-shadow:
        inset 0 0 0 1px color-mix(in oklab, var(--color-bg-light) 12%, transparent),
        0 0 4px 0 rgba(124, 86, 48, 0.34);
    }

    .coming-banner__track {
      display: flex;
      width: max-content;
      gap: 18px;
      padding: 10px 0;
      animation: coming-banner-roll 22s linear infinite;
      will-change: transform;
    }

    .coming-banner__track span {
      position: relative;
      flex: 0 0 auto;
      padding-left: 18px;
      font-family: var(--font-mono);
      font-size: clamp(0.76rem, 1.3vw, 0.95rem);
      line-height: 1;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .coming-banner__track span::before {
      content: "";
      position: absolute;
      left: 0;
      top: 50%;
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: var(--color-orange);
      transform: translateY(-50%);
    }

    @keyframes coming-banner-roll {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-50%);
      }
    }

    .project-sparks {
      position: relative;
      overflow: hidden;
      border-radius: 12px;
      min-height: 190px;
      display: grid;
      grid-template-columns: minmax(0, 0.62fr) minmax(240px, 1fr);
      align-items: center;
      gap: clamp(16px, 4vw, 44px);
      padding: clamp(18px, 3vw, 30px);
      background:
        linear-gradient(135deg, color-mix(in oklab, var(--color-teal) 13%, white), transparent 50%),
        var(--color-bg-light);
      box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 10%, transparent);
    }

    .project-sparks::before {
      content: "";
      position: absolute;
      inset: 16px;
      border-radius: 10px;
      border: 1px dashed color-mix(in oklab, var(--color-ink) 18%, transparent);
      pointer-events: none;
    }

    .project-sparks__copy,
    .project-sparks__art {
      position: relative;
      z-index: 1;
    }

    .project-sparks__copy {
      display: grid;
      gap: 6px;
    }

    .project-sparks__copy p {
      margin: 0;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      line-height: 1;
      text-transform: uppercase;
      color: var(--color-ink-dim);
    }

    .project-sparks__copy h2 {
      margin: 0;
      max-width: 10ch;
      font-family: var(--font-display);
      font-weight: 300;
      font-size: clamp(2.6rem, 6vw, 5.6rem);
      line-height: 0.9;
      color: var(--color-ink);
    }

    .project-sparks__art {
      min-height: 132px;
    }

    .project-sparks__art span {
      position: absolute;
      display: block;
      border-radius: 999px;
      background: var(--color-teal);
      box-shadow: 0 18px 38px -26px rgba(36, 36, 36, 0.62);
    }

    .project-sparks__art span:nth-child(1) {
      left: 5%;
      top: 12%;
      width: 38%;
      height: 12px;
      background: var(--color-orange);
      transform: rotate(-8deg);
    }

    .project-sparks__art span:nth-child(2) {
      left: 20%;
      bottom: 10%;
      width: 64%;
      height: 18px;
      background: var(--color-teal);
      transform: rotate(4deg);
    }

    .project-sparks__art span:nth-child(3) {
      right: 10%;
      top: 16%;
      width: 74px;
      height: 74px;
      background: transparent;
      border: 2px solid var(--color-pink);
      box-shadow: none;
    }

    .project-sparks__art span:nth-child(4) {
      left: 4%;
      bottom: 28%;
      width: 44px;
      height: 44px;
      background: var(--color-bg-neutral-2);
    }

    .project-sparks__art span:nth-child(5) {
      right: 32%;
      top: 48%;
      width: 18px;
      height: 18px;
      background: var(--color-pink);
    }

    @media (min-width: 1180px) {
      .work-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (min-width: 860px) and (max-width: 1179px) {
      .work-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 760px) {
      .work-hero {
        grid-template-columns: 1fr;
        min-height: 0;
      }
      .work-hero h1 {
        font-size: 38px;
      }
      .work-hero__signals {
        width: 100%;
      }
      .project-sparks {
        grid-template-columns: 1fr;
      }
      .project-sparks__art {
        min-height: 110px;
      }
    }
  </style>

  <style>
    /*
      Finale reveal: when we arrive from the wallet transition, the cream veil
      fades out while the sidebar slides in from the left and the main content
      fades up, staggered. The `data-finale-arrival` attribute on <html> is
      set by the script below when a `sessionStorage.wallet:arrival` flag is
      present (set by the onboarding wallet on submit); a direct visit to
      /home skips the finale and shows content immediately.
    */
    .home-veil {
      opacity: 0;
      transition: opacity 640ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    html[data-finale-arrival] .home-veil {
      opacity: 1;
      animation: home-veil-peel 1100ms cubic-bezier(0.22, 1, 0.36, 1) 180ms forwards;
    }
    @keyframes home-veil-peel {
      0% {
        opacity: 1;
        transform: translateY(0);
      }
      60% {
        opacity: 0.25;
        transform: translateY(-6%);
      }
      100% {
        opacity: 0;
        transform: translateY(-14%);
      }
    }

    html[data-finale-arrival] [data-home-shell] > [data-sidebar],
    html[data-finale-arrival] [data-home-stack] > * {
      opacity: 0;
    }
    html[data-finale-arrival] [data-home-shell] > [data-sidebar] {
      animation: home-navbar-slide 620ms cubic-bezier(0.22, 1, 0.36, 1) 320ms forwards;
    }
    html[data-finale-arrival] [data-home-stack] > * {
      animation: home-main-rise 680ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    html[data-finale-arrival] [data-home-stack] > *:nth-child(1) {
      animation-delay: 480ms;
    }
    html[data-finale-arrival] [data-home-stack] > *:nth-child(2) {
      animation-delay: 620ms;
    }

    @keyframes home-navbar-slide {
      from {
        opacity: 0;
        transform: translateY(-18px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes home-main-rise {
      from {
        opacity: 0;
        transform: translateY(22px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .home-veil,
      html[data-finale-arrival] .home-veil,
      html[data-finale-arrival] [data-home-shell] > [data-sidebar],
      html[data-finale-arrival] [data-home-stack] > * {
        animation: none !important;
        transition: none !important;
        opacity: 1;
        transform: none;
      }
      html[data-finale-arrival] .home-veil {
        opacity: 0;
      }
    }
  </style>

  <script>
    /*
      Position the Lingofable / Skloňuj preview cards via fixed coords clamped
      to the viewport so long text doesn't push the popup off-screen.
    */
    function wireSitePreviews() {
      const PREVIEW_W = 240;
      const MARGIN = 12;
      document
        .querySelectorAll<HTMLElement>("[data-site-preview]:not([data-wired])")
        .forEach((link) => {
          link.dataset.wired = "1";
          const preview = link.querySelector<HTMLElement>(".latest-log__preview");
          if (!preview) return;
          // Defer thumb image fetch until hover/focus — saves a request +
          // decode on initial /home paint without changing visual behavior.
          const thumb = preview.querySelector<HTMLElement>(".site-preview__thumb");
          if (thumb && thumb.style.backgroundImage && thumb.style.backgroundImage !== "none") {
            thumb.dataset.bg = thumb.style.backgroundImage;
            thumb.style.backgroundImage = "none";
          }
          let pending = 0;
          const place = () => {
            if (pending) return;
            pending = requestAnimationFrame(() => {
              pending = 0;
              const r = link.getBoundingClientRect();
              const anchorX = r.left + r.width / 2;
              const x = Math.max(
                MARGIN,
                Math.min(window.innerWidth - PREVIEW_W - MARGIN, anchorX - PREVIEW_W / 2),
              );
              const ph = preview.offsetHeight || 176;
              let y = r.top - ph - MARGIN;
              if (y < MARGIN) y = r.bottom + MARGIN;
              preview.style.setProperty("--preview-x", `${x}px`);
              preview.style.setProperty("--preview-y", `${y}px`);
            });
          };
          const onEnter = () => {
            if (thumb && thumb.dataset.bg) {
              thumb.style.backgroundImage = thumb.dataset.bg;
              delete thumb.dataset.bg;
            }
            place();
          };
          link.addEventListener("pointerenter", onEnter);
          link.addEventListener("focus", onEnter);
        });
    }
    wireSitePreviews();
    document.addEventListener("astro:page-load", wireSitePreviews);

    /*
      Detect arrival from the wallet transition. The onboarding submit handler
      sets `wallet:arrival` in sessionStorage right before navigate(); we
      consume it here on /home mount and arm the finale animations. If the
      flag is missing (direct visit, reload), we hide the veil immediately.

      Runs on every ClientRouter swap via `astro:page-load` so SPA-style
      returns to /home also pick up the flag correctly.
    */
    function armFinale() {
      let arrived = false;
      try {
        arrived = sessionStorage.getItem("wallet:arrival") === "1";
        if (arrived) sessionStorage.removeItem("wallet:arrival");
      } catch {
        arrived = false;
      }

      (window as any).__walletArrived = arrived;
      const root = document.documentElement;
      if (arrived) {
        root.setAttribute("data-finale-arrival", "");
        // Clean up the attribute once the animation has finished so future
        // CSS changes don't re-trigger anything on subsequent renders. The
        // combined animation (veil peel + footer slide) lands around 1.55s.
        window.setTimeout(() => {
          root.removeAttribute("data-finale-arrival");
          const veil = document.querySelector<HTMLElement>("[data-home-veil]");
          if (veil) veil.style.display = "none";
        }, 2000);
      } else {
        // Direct visit — hide the veil up-front so the page reads normally.
        const veil = document.querySelector<HTMLElement>("[data-home-veil]");
        if (veil) veil.style.display = "none";
      }
    }
    armFinale();
    document.addEventListener("astro:page-load", armFinale);
  </script>
</BaseLayout>
