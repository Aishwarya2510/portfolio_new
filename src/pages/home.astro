---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/home/Sidebar.astro";
import LatestLog from "../components/home/LatestLog.astro";
import ProjectIndexCard from "../components/home/ProjectIndexCard.astro";
import CustomCursor from "../components/home/CustomCursor.astro";
import { workProjects as projects } from "../lib/work-projects";

export const prerender = false;
---

<BaseLayout
  title="Aishwarya's Portfolio"
  description="Aishwarya's portfolio - AI strategy, product management, data quality, and technology management projects."
>
  <!--
    Wallet finale veil. Shares `transition:name="wallet-veil"` with the
    cream backdrop on the onboarding wallet overlay, so the cream persists
    across the ClientRouter nav from /onboarding → /home and then peels back
    here. If the visitor lands on /home directly (refresh, deep-link), the
    script below hides the veil immediately so the page reads normally.
  -->
  <div
    data-home-veil
    transition:name="wallet-veil"
    aria-hidden="true"
    class="home-veil fixed inset-0 z-50 bg-[var(--color-bg)] pointer-events-none"
  >
  </div>

  <div class="flex flex-col min-h-screen" data-home-shell>
    <Sidebar anon />

    <main class="home-main flex flex-col gap-3 p-3 sm:p-4 md:p-5 flex-1 min-w-0" data-home-main>
      <div class="flex flex-col gap-4" data-home-stack>
        <LatestLog date="Latest project">
          Snowflake Cortex Analyst sharpened my view on enterprise AI: polished demos may impress,
          but production systems earn trust through governance, evaluation loops, observability,
          semantic context, and human judgment.
        </LatestLog>

        <div class="work-grid">
          {
            projects.map((project, index) => (
              <ProjectIndexCard
                title={project.title}
                slug={project.slug}
                number={index + 1}
                role={project.role}
                team={project.team}
                shipped={project.shipped}
                status={project.status}
                description={project.description}
                accent={project.accent}
                image={project.images[0]}
                imageHeight={96}
                href={`/work/${project.slug}`}
                tilt={0}
              />
            ))
          }
        </div>
      </div>
    </main>
  </div>

  <CustomCursor color="teal" />

  <style is:global>
    /*
      Inline site-preview chips — hovering "Lingofable" / "Skloňuj" inside the
      LatestLog surfaces a mini browser window with the site thumbnail.
    */
    .latest-log__site-link {
      position: relative;
      color: var(--color-ink-inverted);
      text-decoration: underline;
      text-underline-offset: 2px;
      text-decoration-thickness: 1px;
      text-decoration-color: color-mix(in oklab, var(--color-ink-inverted) 40%, transparent);
      transition: text-decoration-color var(--duration-fast) var(--ease-out-soft);
    }
    .latest-log__site-link:hover {
      text-decoration-color: var(--color-ink-inverted);
    }
    .latest-log__preview {
      position: fixed;
      top: 0;
      left: 0;
      width: 240px;
      padding: 8px;
      border-radius: 10px;
      background: var(--color-bg-light);
      border: 1px solid color-mix(in oklab, var(--color-ink) 10%, transparent);
      box-shadow:
        0 18px 36px -16px rgba(36, 36, 36, 0.55),
        0 4px 10px -4px rgba(36, 36, 36, 0.35);
      pointer-events: none;
      opacity: 0;
      transform: translate(var(--preview-x, 0px), calc(var(--preview-y, 0px) + 6px)) scale(0.97);
      transform-origin: bottom center;
      transition:
        opacity 200ms var(--ease-out-soft),
        transform 240ms var(--ease-out-soft);
      z-index: 50;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .latest-log__site-link:hover .latest-log__preview,
    .latest-log__site-link:focus-visible .latest-log__preview {
      opacity: 1;
      transform: translate(var(--preview-x, 0px), var(--preview-y, 0px)) scale(1);
    }
    .site-preview__chrome {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0 2px;
    }
    .site-preview__dots {
      display: inline-flex;
      gap: 3px;
    }
    .site-preview__dots i {
      display: block;
      width: 5px;
      height: 5px;
      border-radius: 9999px;
      background: color-mix(in oklab, var(--color-ink) 30%, transparent);
    }
    .site-preview__url {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.02em;
      text-transform: none;
      color: var(--color-ink-dim);
    }
    .site-preview__thumb {
      display: block;
      width: 100%;
      height: 120px;
      border-radius: 6px;
      background-size: cover;
      background-position: center top;
      background-color: var(--color-bg-neutral);
    }

    @media (prefers-reduced-motion: reduce) {
      .latest-log__preview {
        transition: opacity 120ms var(--ease-out-soft);
        transform: translate(var(--preview-x, 0px), var(--preview-y, 0px));
      }
      .latest-log__site-link:hover .latest-log__preview {
        transform: translate(var(--preview-x, 0px), var(--preview-y, 0px));
      }
    }

    .work-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 14px;
      align-items: stretch;
    }

    @media (min-width: 1180px) {
      .work-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
    }

    @media (min-width: 860px) and (max-width: 1179px) {
      .work-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  </style>

  <style>
    /*
      Finale reveal: when we arrive from the wallet transition, the cream veil
      fades out while the sidebar slides in from the left and the main content
      fades up, staggered. The `data-finale-arrival` attribute on <html> is
      set by the script below when a `sessionStorage.wallet:arrival` flag is
      present (set by the onboarding wallet on submit); a direct visit to
      /home skips the finale and shows content immediately.
    */
    .home-veil {
      opacity: 0;
      transition: opacity 640ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    html[data-finale-arrival] .home-veil {
      opacity: 1;
      animation: home-veil-peel 1100ms cubic-bezier(0.22, 1, 0.36, 1) 180ms forwards;
    }
    @keyframes home-veil-peel {
      0% {
        opacity: 1;
        transform: translateY(0);
      }
      60% {
        opacity: 0.25;
        transform: translateY(-6%);
      }
      100% {
        opacity: 0;
        transform: translateY(-14%);
      }
    }

    html[data-finale-arrival] [data-home-shell] > [data-sidebar],
    html[data-finale-arrival] [data-home-stack] > * {
      opacity: 0;
    }
    html[data-finale-arrival] [data-home-shell] > [data-sidebar] {
      animation: home-navbar-slide 620ms cubic-bezier(0.22, 1, 0.36, 1) 320ms forwards;
    }
    html[data-finale-arrival] [data-home-stack] > * {
      animation: home-main-rise 680ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    html[data-finale-arrival] [data-home-stack] > *:nth-child(1) {
      animation-delay: 480ms;
    }
    html[data-finale-arrival] [data-home-stack] > *:nth-child(2) {
      animation-delay: 620ms;
    }

    @keyframes home-navbar-slide {
      from {
        opacity: 0;
        transform: translateY(-18px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes home-main-rise {
      from {
        opacity: 0;
        transform: translateY(22px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .home-veil,
      html[data-finale-arrival] .home-veil,
      html[data-finale-arrival] [data-home-shell] > [data-sidebar],
      html[data-finale-arrival] [data-home-stack] > * {
        animation: none !important;
        transition: none !important;
        opacity: 1;
        transform: none;
      }
      html[data-finale-arrival] .home-veil {
        opacity: 0;
      }
    }
  </style>

  <script>
    /*
      Position the Lingofable / Skloňuj preview cards via fixed coords clamped
      to the viewport so long text doesn't push the popup off-screen.
    */
    function wireSitePreviews() {
      const PREVIEW_W = 240;
      const MARGIN = 12;
      document
        .querySelectorAll<HTMLElement>("[data-site-preview]:not([data-wired])")
        .forEach((link) => {
          link.dataset.wired = "1";
          const preview = link.querySelector<HTMLElement>(".latest-log__preview");
          if (!preview) return;
          // Defer thumb image fetch until hover/focus — saves a request +
          // decode on initial /home paint without changing visual behavior.
          const thumb = preview.querySelector<HTMLElement>(".site-preview__thumb");
          if (thumb && thumb.style.backgroundImage && thumb.style.backgroundImage !== "none") {
            thumb.dataset.bg = thumb.style.backgroundImage;
            thumb.style.backgroundImage = "none";
          }
          let pending = 0;
          const place = () => {
            if (pending) return;
            pending = requestAnimationFrame(() => {
              pending = 0;
              const r = link.getBoundingClientRect();
              const anchorX = r.left + r.width / 2;
              const x = Math.max(
                MARGIN,
                Math.min(window.innerWidth - PREVIEW_W - MARGIN, anchorX - PREVIEW_W / 2),
              );
              const ph = preview.offsetHeight || 176;
              let y = r.top - ph - MARGIN;
              if (y < MARGIN) y = r.bottom + MARGIN;
              preview.style.setProperty("--preview-x", `${x}px`);
              preview.style.setProperty("--preview-y", `${y}px`);
            });
          };
          const onEnter = () => {
            if (thumb && thumb.dataset.bg) {
              thumb.style.backgroundImage = thumb.dataset.bg;
              delete thumb.dataset.bg;
            }
            place();
          };
          link.addEventListener("pointerenter", onEnter);
          link.addEventListener("focus", onEnter);
        });
    }
    wireSitePreviews();
    document.addEventListener("astro:page-load", wireSitePreviews);

    /*
      Detect arrival from the wallet transition. The onboarding submit handler
      sets `wallet:arrival` in sessionStorage right before navigate(); we
      consume it here on /home mount and arm the finale animations. If the
      flag is missing (direct visit, reload), we hide the veil immediately.

      Runs on every ClientRouter swap via `astro:page-load` so SPA-style
      returns to /home also pick up the flag correctly.
    */
    function armFinale() {
      let arrived = false;
      try {
        arrived = sessionStorage.getItem("wallet:arrival") === "1";
        if (arrived) sessionStorage.removeItem("wallet:arrival");
      } catch {
        arrived = false;
      }

      (window as any).__walletArrived = arrived;
      const root = document.documentElement;
      if (arrived) {
        root.setAttribute("data-finale-arrival", "");
        // Clean up the attribute once the animation has finished so future
        // CSS changes don't re-trigger anything on subsequent renders. The
        // combined animation (veil peel + footer slide) lands around 1.55s.
        window.setTimeout(() => {
          root.removeAttribute("data-finale-arrival");
          const veil = document.querySelector<HTMLElement>("[data-home-veil]");
          if (veil) veil.style.display = "none";
        }, 2000);
      } else {
        // Direct visit — hide the veil up-front so the page reads normally.
        const veil = document.querySelector<HTMLElement>("[data-home-veil]");
        if (veil) veil.style.display = "none";
      }
    }
    armFinale();
    document.addEventListener("astro:page-load", armFinale);
  </script>
</BaseLayout>
