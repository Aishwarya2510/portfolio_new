---
import { existsSync, readdirSync } from "node:fs";
import { extname, join } from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/home/Sidebar.astro";
import CustomCursor from "../components/home/CustomCursor.astro";
import { withBase } from "../lib/paths";

const imageExtensions = new Set([".jpg", ".jpeg", ".png", ".webp", ".avif"]);

function publicImageList(folder: string) {
  const absoluteFolder = join(process.cwd(), "public", "images", folder);
  if (!existsSync(absoluteFolder)) return [];

  return readdirSync(absoluteFolder)
    .filter((file) => imageExtensions.has(extname(file).toLowerCase()))
    .sort((a, b) => a.localeCompare(b))
    .map((file) => withBase(`/images/${folder}/${file}`));
}

const personalPhotos = publicImageList("me");
const bookPosters = publicImageList("books");
const seriesPosters = publicImageList("series");
const moviePosters = publicImageList("movies");

const shelves = [
  {
    label: "On the Nightstand",
    title: "Books",
    copy: "Deeply into world-building and sharp narratives. Currently rotating between high-fantasy epics, reflective reads, and deep dives into technology history.",
    posters: bookPosters,
    layout: "static",
  },
  {
    label: "Binge-Worthy",
    title: "Series",
    copy: "I appreciate brilliant storytelling, sharp dialogue, and complex characters. If a show has incredible cinematography or a mind-bending plot twist, I'm hooked.",
    posters: seriesPosters,
    layout: "rail",
  },
  {
    label: "Movie Queue",
    title: "Movies",
    copy: "Comfort rewatches, big-screen chaos, clever sci-fi, classic romance, and anything that can make a room collectively gasp.",
    posters: moviePosters,
    layout: "rail",
  },
];
---

<BaseLayout
  title="About - Aishwarya's Portfolio"
  description="A more personal note about Aishwarya Choursia: Mumbai roots, dancing, technology, stories, and building a life in the US."
>
  <div class="about-shell">
    <Sidebar active="about" />

    <main class="about-main">
      <section class="about-intro">
        <section class="photo-strip" aria-label="Candid snapshots">
          {
            personalPhotos.slice(0, 3).map((photo, index) => (
              <figure class={`photo-card photo-card--${index + 1}`}>
                <img src={photo} alt={`Candid snapshot ${index + 1}`} loading="lazy" />
              </figure>
            ))
          }
        </section>

        <div class="about-copy">
          <p class="about-kicker">About me</p>
          <h1>I'm Aishwarya Choursia.</h1>
          <div class="bio-copy">
            <p>
              I am from the city of dreams, Mumbai, which probably explains why I have always been
              drawn to big energy, crowded stories, late-night ideas, and people trying to build
              something meaningful from scratch.
            </p>
            <p>
              I came to the US in 2023, and I am still enjoying the mix of new places, new routines,
              new weather opinions, and the quiet thrill of figuring out a life chapter in real
              time.
            </p>
            <p>
              Outside work, I love dancing, getting way too invested in books and shows, exploring
              cafes, learning how technology is changing the world, and building things that feel
              useful, creative, and a little bit ambitious.
            </p>
          </div>
        </div>
      </section>

      <section class="personal-shelves" aria-label="Personal favorites">
        {
          shelves.map((shelf, index) => (
            <article class={`media-shelf media-shelf--${index + 1}`}>
              <div class="media-copy">
                <p class="about-kicker">{shelf.label}</p>
                <h2>{shelf.title}</h2>
                <p>{shelf.copy}</p>
              </div>

              {shelf.layout === "static" ? (
                <div class="poster-grid" aria-label={`${shelf.title} posters`}>
                  {shelf.posters.map((poster) => (
                    <img src={poster} alt="" loading="lazy" />
                  ))}
                </div>
              ) : (
                <div class="poster-rail" aria-label={`${shelf.title} posters`}>
                  <div class="poster-track">
                    {[...shelf.posters, ...shelf.posters].map((poster) => (
                      <img src={poster} alt="" loading="lazy" />
                    ))}
                  </div>
                </div>
              )}
            </article>
          ))
        }
      </section>
    </main>
  </div>

  <CustomCursor color="teal" />
</BaseLayout>

<style>
  .about-shell {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    min-height: 100vh;
    background:
      radial-gradient(circle at 86% 12%, rgba(179, 208, 213, 0.32), transparent 18rem),
      radial-gradient(circle at 14% 88%, rgba(238, 188, 148, 0.32), transparent 20rem),
      var(--color-bg);
    color: var(--color-ink);
  }

  .about-main {
    position: relative;
    flex: 1;
    min-width: 0;
    display: grid;
    gap: 16px;
    padding: 14px clamp(12px, 3vw, 28px) 18px;
  }

  .about-intro,
  .photo-strip,
  .media-shelf {
    border-radius: 10px;
    background: var(--color-bg-light);
    box-shadow: 0 0 4px 0 #999079;
  }

  .about-intro {
    display: grid;
    grid-template-columns: minmax(420px, 1.08fr) minmax(300px, 0.72fr);
    gap: clamp(16px, 3vw, 34px);
    align-items: center;
    padding: clamp(16px, 2.4vw, 26px);
    background:
      linear-gradient(135deg, color-mix(in oklab, var(--color-teal) 12%, white), transparent 44%),
      var(--color-bg-light);
  }

  .about-copy {
    display: grid;
    align-content: center;
    gap: 12px;
    min-width: 0;
  }

  .about-kicker {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-transform: uppercase;
    color: var(--color-ink-dim);
  }

  .about-intro h1,
  .media-copy h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 300;
    color: var(--color-ink);
  }

  .about-intro h1 {
    font-size: clamp(2.7rem, 4.5vw, 5.1rem);
    line-height: 0.9;
  }

  .bio-copy {
    display: grid;
    gap: 12px;
    max-width: 58ch;
  }

  .bio-copy p,
  .media-copy > p:last-child {
    margin: 0;
    color: var(--color-ink-dim);
    font-size: clamp(0.98rem, 1.25vw, 1.08rem);
    line-height: 1.55;
  }

  .photo-strip {
    display: grid;
    grid-template-columns: minmax(180px, 0.72fr) minmax(260px, 1.3fr) minmax(180px, 0.7fr);
    gap: clamp(10px, 2vw, 22px);
    align-items: center;
    min-width: 0;
    padding: 0;
    overflow: hidden;
    background: color-mix(in oklab, var(--color-bg-light) 86%, white);
  }

  .photo-card {
    margin: 0;
    overflow: hidden;
    border-radius: 10px;
    background: var(--color-bg-neutral);
    box-shadow:
      0 18px 30px -24px rgba(36, 36, 36, 0.86),
      inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 8%, transparent);
  }

  .photo-card--1 {
    aspect-ratio: 0.72;
    transform: translateY(-8px);
  }

  .photo-card--2 {
    position: relative;
    aspect-ratio: 1.8;
    transform: translateY(14px);
  }

  .photo-card--2::before {
    content: "";
    position: absolute;
    left: -14px;
    top: 34px;
    z-index: 2;
    width: 86px;
    height: 20px;
    border-radius: 999px;
    background: var(--color-pink);
  }

  .photo-card--3 {
    aspect-ratio: 0.78;
    transform: translateY(-4px);
  }

  .photo-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .personal-shelves {
    display: grid;
    gap: 16px;
    min-width: 0;
  }

  .media-shelf {
    display: grid;
    grid-template-columns: minmax(220px, 0.32fr) minmax(0, 1fr);
    gap: clamp(16px, 3vw, 36px);
    align-items: center;
    min-width: 0;
    overflow: hidden;
    padding: clamp(18px, 3vw, 30px);
  }

  .media-shelf--1 {
    background:
      linear-gradient(
        135deg,
        color-mix(in oklab, var(--color-orange-1) 18%, white),
        transparent 48%
      ),
      var(--color-bg-light);
  }

  .media-shelf--2 {
    background:
      linear-gradient(135deg, rgba(36, 36, 36, 0.94), rgba(36, 36, 36, 0.82)), var(--color-ink);
  }

  .media-shelf--3 {
    background:
      linear-gradient(135deg, color-mix(in oklab, var(--color-teal) 14%, white), transparent 50%),
      var(--color-bg-light);
  }

  .media-shelf--2 .about-kicker,
  .media-shelf--2 .media-copy > p:last-child {
    color: rgba(255, 255, 255, 0.72);
  }

  .media-shelf--2 .media-copy h2 {
    color: var(--color-bg-light);
  }

  .media-copy {
    display: grid;
    gap: 10px;
    min-width: 0;
  }

  .media-copy h2 {
    font-size: clamp(2.3rem, 5vw, 5.4rem);
    line-height: 0.9;
  }

  .poster-rail {
    min-width: 0;
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 7%, black 93%, transparent);
  }

  .poster-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(96px, 1fr));
    gap: 12px;
    min-width: 0;
  }

  .poster-track {
    display: flex;
    width: max-content;
    gap: 10px;
    animation: poster-scroll 38s linear infinite;
  }

  .media-shelf:nth-child(even) .poster-track {
    animation-direction: reverse;
  }

  .poster-track img,
  .poster-grid img {
    display: block;
    width: clamp(88px, 10vw, 148px);
    aspect-ratio: 2 / 3;
    flex: 0 0 auto;
    border-radius: 7px;
    background: var(--color-bg-white);
    object-fit: cover;
    box-shadow: 0 14px 26px -20px rgba(36, 36, 36, 0.85);
  }

  .poster-grid img {
    width: 100%;
  }

  @keyframes poster-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 900px) {
    .about-intro,
    .media-shelf {
      grid-template-columns: 1fr;
    }

    .photo-strip {
      grid-template-columns: 0.75fr 1fr;
      padding: 0;
    }

    .photo-card--3 {
      grid-column: 1 / -1;
      aspect-ratio: 1.8;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .about-shell {
      display: block;
    }

    .about-main {
      padding-inline: 12px;
    }

    .about-intro,
    .photo-strip,
    .media-shelf {
      padding: 16px;
    }

    .about-intro h1 {
      font-size: clamp(3rem, 17vw, 4.6rem);
      overflow-wrap: anywhere;
    }

    .photo-strip {
      grid-template-columns: 1fr;
    }

    .photo-card,
    .photo-card--1,
    .photo-card--2,
    .photo-card--3 {
      aspect-ratio: 1.08;
      transform: none;
    }

    .photo-card--2::before {
      left: 16px;
      top: 14px;
      width: 72px;
      height: 16px;
    }

    .media-copy h2 {
      font-size: clamp(2.4rem, 15vw, 4rem);
    }

    .poster-track img,
    .poster-grid img {
      width: 88px;
    }

    .poster-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .poster-track {
      animation: none !important;
    }
  }
</style>
