---
import BaseLayout from "../layouts/BaseLayout.astro";
import CustomCursor from "../components/home/CustomCursor.astro";
import { withBase } from "../lib/paths";
---

<BaseLayout
  title="Not Instagram - Aishwarya's Portfolio"
  description="A playful not-Instagram detour from Aishwarya's portfolio."
>
  <main class="not-insta-page">
    <a class="back-link" href={withBase("/connect/")} data-cursor="link">Back to connect</a>

    <section class="joke-card" aria-labelledby="not-insta-title">
      <div class="monster" aria-hidden="true">
        <div class="monster__horns"><span></span><span></span></div>
        <div class="monster__face">
          <span class="monster__eye"></span>
          <span class="monster__eye"></span>
          <span class="monster__smile"></span>
        </div>
        <div class="monster__feet"><span></span><span></span></div>
      </div>

      <div class="copy">
        <p class="kicker">Haha, just for fun</p>
        <h1 id="not-insta-title">Sorry, not sharing it.</h1>
        <p>
          The Instagram portal is currently guarded by vibes, privacy, and one very dramatic little
          monster.
        </p>
        <p class="emoji-line" aria-label="playful emojis">✨ 🚀 ☕ 🤖 🎉</p>
      </div>
    </section>
  </main>

  <CustomCursor color="orange" />
</BaseLayout>

<style>
  .not-insta-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: clamp(16px, 4vw, 44px);
    background:
      radial-gradient(circle at 12% 16%, rgba(244, 213, 111, 0.32), transparent 18rem),
      radial-gradient(circle at 88% 82%, rgba(179, 208, 213, 0.34), transparent 22rem),
      var(--color-bg);
    color: var(--color-ink);
  }

  .back-link {
    position: fixed;
    left: clamp(14px, 3vw, 28px);
    top: clamp(14px, 3vw, 28px);
    border-radius: var(--radius-sm);
    padding: 10px 13px;
    background: var(--color-ink);
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
  }

  .joke-card {
    width: min(920px, 100%);
    display: grid;
    grid-template-columns: minmax(220px, 0.58fr) minmax(0, 1fr);
    gap: clamp(22px, 5vw, 54px);
    align-items: center;
    border-radius: 18px;
    padding: clamp(22px, 5vw, 56px);
    background: var(--color-bg-light);
    box-shadow:
      0 28px 70px -52px rgba(36, 36, 36, 0.86),
      inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 9%, transparent);
  }

  .monster {
    position: relative;
    width: min(300px, 74vw);
    aspect-ratio: 1;
    justify-self: center;
    display: grid;
    place-items: center;
    animation: bob 2.8s ease-in-out infinite;
  }

  .monster__face {
    position: relative;
    width: 78%;
    height: 72%;
    border-radius: 34% 34% 42% 42%;
    background:
      radial-gradient(circle at 30% 26%, rgba(255, 255, 255, 0.42), transparent 22%),
      var(--color-teal);
    box-shadow:
      inset 0 -18px 0 rgba(23, 41, 74, 0.12),
      0 24px 34px -26px rgba(36, 36, 36, 0.82);
  }

  .monster__horns span,
  .monster__feet span {
    position: absolute;
    display: block;
    background: var(--color-orange);
  }

  .monster__horns span {
    top: 8%;
    width: 46px;
    height: 62px;
    border-radius: 999px 999px 8px 8px;
  }

  .monster__horns span:first-child {
    left: 24%;
    rotate: -22deg;
  }

  .monster__horns span:last-child {
    right: 24%;
    rotate: 22deg;
  }

  .monster__eye {
    position: absolute;
    top: 36%;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: var(--color-ink);
  }

  .monster__eye:first-child {
    left: 28%;
  }

  .monster__eye:nth-child(2) {
    right: 28%;
  }

  .monster__smile {
    position: absolute;
    left: 50%;
    top: 54%;
    width: 78px;
    height: 38px;
    border-bottom: 8px solid var(--color-ink);
    border-radius: 0 0 999px 999px;
    translate: -50% 0;
  }

  .monster__feet span {
    bottom: 6%;
    width: 58px;
    height: 28px;
    border-radius: 999px;
  }

  .monster__feet span:first-child {
    left: 28%;
  }

  .monster__feet span:last-child {
    right: 28%;
  }

  .copy {
    display: grid;
    gap: 14px;
  }

  .kicker {
    margin: 0;
    color: var(--color-ink-dim);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 8vw, 7rem);
    font-weight: 300;
    line-height: 0.88;
    color: var(--color-ink);
  }

  .copy p:not(.kicker) {
    max-width: 48ch;
    margin: 0;
    color: var(--color-ink-dim);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.55;
  }

  .emoji-line {
    font-size: clamp(1.8rem, 4vw, 3rem);
    letter-spacing: 0.08em;
  }

  @keyframes bob {
    0%,
    100% {
      transform: translateY(0) rotate(-1deg);
    }
    50% {
      transform: translateY(-10px) rotate(1deg);
    }
  }

  @media (max-width: 760px) {
    .joke-card {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .copy p {
      justify-self: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .monster {
      animation: none;
    }
  }
</style>
