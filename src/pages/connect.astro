---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/home/Sidebar.astro";
import CustomCursor from "../components/home/CustomCursor.astro";
import { withBase } from "../lib/paths";

const formspreeEndpoint =
  import.meta.env.PUBLIC_FORMSPREE_ENDPOINT ?? "https://formspree.io/f/your-form-id";

const socials = [
  { label: "LinkedIn", href: "#", note: "professional updates" },
  { label: "GitHub", href: "#", note: "projects and code" },
  { label: "Email", href: "mailto:hello@example.com", note: "direct hello" },
  { label: "Portfolio", href: withBase("/home/"), note: "selected work" },
];
---

<BaseLayout
  title="Connect - Aishwarya's Portfolio"
  description="Contact Aishwarya Choursia for AI transformation, product strategy, and operations work."
>
  <div class="connect-shell">
    <Sidebar active="connect" />

    <main class="connect-main">
      <section class="connect-panel connect-panel--intro">
        <p class="connect-kicker">Connect with me</p>
        <h1>Let's build something useful.</h1>
        <p>
          Send a quick note about the problem, idea, role, project, or collaboration you have in
          mind. Short messages are perfect.
        </p>

        <div class="social-links" aria-label="Social links">
          {
            socials.map((social) => (
              <a href={social.href} class="social-link" data-cursor="link">
                <span>{social.label}</span>
                <small>{social.note}</small>
              </a>
            ))
          }
        </div>
      </section>

      <section class="connect-panel connect-panel--form">
        <form action={formspreeEndpoint} method="POST" class="connect-form">
          <input type="hidden" name="_subject" value="New portfolio contact" />

          <label>
            <span>Name</span>
            <input name="name" type="text" autocomplete="name" required />
          </label>

          <label>
            <span>Email</span>
            <input name="email" type="email" autocomplete="email" required />
          </label>

          <label>
            <span>Contact</span>
            <input name="contact" type="tel" autocomplete="tel" />
          </label>

          <label class="connect-form__message">
            <span>Short message</span>
            <textarea name="message" rows="5" required></textarea>
          </label>

          <button type="submit" data-cursor="link">Send message</button>
        </form>
      </section>
    </main>
  </div>

  <CustomCursor color="orange" />
</BaseLayout>

<style>
  .connect-shell {
    min-height: 100vh;
    background:
      linear-gradient(135deg, transparent 0 70%, rgba(244, 213, 111, 0.26) 70% 80%, transparent 80%),
      linear-gradient(45deg, transparent 0 64%, rgba(248, 231, 160, 0.42) 64% 75%, transparent 75%),
      radial-gradient(circle at 18% 18%, rgba(240, 208, 102, 0.28), transparent 18rem),
      var(--color-bg);
    color: var(--color-ink);
  }

  .connect-main {
    display: grid;
    grid-template-columns: minmax(280px, 0.46fr) minmax(320px, 0.54fr);
    gap: 16px;
    min-height: calc(100vh - 79px);
    padding: 16px clamp(14px, 3vw, 34px) 24px;
  }

  .connect-panel {
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 16px 38px -30px rgba(23, 41, 74, 0.28), 0 0 4px rgba(123, 106, 69, 0.18);
  }

  .connect-panel--intro {
    display: grid;
    align-content: center;
    gap: 14px;
    padding: clamp(18px, 3vw, 34px);
  }

  .connect-kicker {
    margin: 0;
    color: var(--color-ink-dim);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-transform: uppercase;
  }

  .connect-panel h1 {
    max-width: 9ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.7vw, 4.55rem);
    font-weight: 300;
    line-height: 0.94;
    overflow-wrap: anywhere;
  }

  .connect-panel p {
    max-width: 42ch;
    margin: 0;
    color: var(--color-ink-dim);
    font-size: 0.95rem;
    line-height: 1.38;
  }

  .social-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 8px;
  }

  .social-link {
    display: grid;
    gap: 4px;
    min-height: 74px;
    border-radius: 8px;
    padding: 12px;
    background: var(--color-bg-neutral);
    color: var(--color-ink);
    text-decoration: none;
    transition:
      transform var(--duration-base) var(--ease-out-soft),
      background var(--duration-base) var(--ease-out-soft);
  }

  .social-link:hover {
    transform: translateY(-2px);
    background: var(--color-orange-2);
  }

  .social-link span {
    font-family: var(--font-display);
    font-size: 1.18rem;
    line-height: 1;
  }

  .social-link small {
    color: var(--color-ink-dim);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
  }

  .connect-panel--form {
    display: grid;
    align-content: center;
    padding: clamp(16px, 2.6vw, 28px);
  }

  .connect-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .connect-form label {
    display: grid;
    gap: 7px;
  }

  .connect-form__message {
    grid-column: 1 / -1;
  }

  .connect-form span {
    color: var(--color-ink-dim);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    text-transform: uppercase;
  }

  .connect-form input,
  .connect-form textarea {
    width: 100%;
    border: 1px solid color-mix(in oklab, var(--color-ink) 14%, transparent);
    border-radius: 8px;
    padding: 10px 11px;
    background: var(--color-bg);
    color: var(--color-ink);
    font: inherit;
    outline: none;
    transition:
      border-color var(--duration-fast) var(--ease-out-soft),
      box-shadow var(--duration-fast) var(--ease-out-soft),
      background var(--duration-fast) var(--ease-out-soft);
  }

  .connect-form textarea {
    min-height: 122px;
    resize: vertical;
  }

  .connect-form input:focus,
  .connect-form textarea:focus {
    border-color: var(--color-orange);
    background: var(--color-bg-light);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-orange) 18%, transparent);
  }

  .connect-form button {
    grid-column: 1 / -1;
    min-height: 48px;
    border: 0;
    border-radius: 999px;
    background: var(--color-ink);
    color: var(--color-ink-inverted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      transform var(--duration-base) var(--ease-out-soft),
      background var(--duration-base) var(--ease-out-soft);
  }

  .connect-form button:hover {
    transform: translateY(-2px);
    background: var(--color-orange);
  }

  @media (max-width: 1100px) {
    .connect-main {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .connect-form,
    .social-links {
      grid-template-columns: 1fr;
    }

    .connect-panel h1 {
      max-width: 15ch;
      font-size: clamp(2.1rem, 12vw, 3.6rem);
    }
  }
</style>
