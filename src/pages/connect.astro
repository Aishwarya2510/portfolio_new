---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sidebar from "../components/home/Sidebar.astro";
import CustomCursor from "../components/home/CustomCursor.astro";`r`nimport { withBase } from "../lib/paths";

const formspreeEndpoint =
  import.meta.env.PUBLIC_FORMSPREE_ENDPOINT ?? "https://formspree.io/f/your-form-id";

const vibeSliders = [
  {
    key: "horizon",
    label: "PROJECT HORIZON",
    minLabel: "Small Concept",
    maxLabel: "Moonshot",
    value: 42,
  },
  {
    key: "energy",
    label: "ENERGY LEVEL",
    minLabel: "Quiet Coffee Chat",
    maxLabel: "High-Octane Build",
    value: 58,
  },
  {
    key: "collaboration",
    label: "COLLABORATION STYLE",
    minLabel: "Human-in-the-Loop",
    maxLabel: "Pure Automation",
    value: 36,
  },
];

const tags = [
  "AI STRATEGY",
  "REVOPS BROWNBAG",
  "LEAN SIX SIGMA",
  "DATA COMPLIANCE",
  "JUST SAYING HI ??",
  "PRODUCT DEMO",
];

const channels = [
  {
    label: "Not Instagram",
    href: "#",
    note: "Plot twist: I am not handing over the scroll vortex today",
    logo: withBase("/images/connectlogos/insta.jpg"),
    action: "joke",
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/aishwarya-chourasia-65b381151/",
    note: "work, ideas, collaborations",
    logo: withBase("/images/connectlogos/linkeidn.png"),
  },
  {
    label: "GitHub",
    href: "https://github.com/Aishwarya2510",
    note: "projects, repos, experiments",
    logo: withBase("/images/connectlogos/git.png"),
  },
  {
    label: "Email",
    href: "mailto:aisharya7uiuc@gmail.com",
    note: "direct note, no ceremony",
    logo: withBase("/images/connectlogos/gmail.png"),
  },
];---

<BaseLayout
  title="Connect - Aishwarya's Portfolio"
  description="A playful AI strategy and product management postcard for connecting with Aishwarya Choursia."
>
  <div
    class="min-h-screen overflow-hidden bg-[radial-gradient(circle_at_10%_12%,rgba(179,208,213,.34),transparent_18rem),radial-gradient(circle_at_90%_80%,rgba(244,213,111,.3),transparent_22rem),var(--color-bg)] text-[var(--color-ink)]"
  >
    <Sidebar active="connect" />

    <main
      class="mx-auto grid w-full max-w-[1500px] gap-4 px-3 pb-6 pt-4 sm:px-5 lg:grid-cols-[minmax(0,0.95fr)_minmax(360px,0.72fr)] lg:px-8"
      data-connect-playground
    >
      <section
        class="rounded-xl bg-white/90 p-5 shadow-[0_16px_42px_-34px_rgba(23,41,74,.42),0_0_4px_rgba(123,106,69,.18)] sm:p-7 lg:min-h-[calc(100vh-112px)]"
      >
        <div class="grid h-full content-between gap-7">
          <div class="grid gap-5">
            <p class="font-mono text-xs uppercase tracking-[0.08em] text-[var(--color-ink-dim)]">
              AI strategy and product playground
            </p>
            <h1
              class="max-w-[10ch] font-display text-[clamp(3.2rem,8vw,8.5rem)] font-light leading-[0.86] text-[var(--color-ink)]"
            >
              Let's build something useful.
            </h1>
            <p class="max-w-2xl text-base leading-7 text-[var(--color-ink-dim)]">
              Shape the ask like a product brief: pick the horizon, set the operating energy, choose
              the collaboration model, and stamp the postcard with what we should talk about.
            </p>
          </div>

          <section class="postcard-wrap" aria-label="Live postcard preview">
            <article class="postcard">
              <header class="postcard__meta">
                <p>
                  POSTCARD FROM:
                  <span data-postcard-name>Someone Awesome</span>
                </p>
                <div class="postcard__stamp" aria-label="Energy stamp">
                  <span>STAMP</span>
                  <strong data-postcard-stamp>🤖</strong>
                </div>
              </header>

              <p class="postcard__to">TO: Aishwarya Chourasia</p>

              <div class="postcard__body">
                <p>Hello Aishwarya,</p>
                <p>
                  I'm dropping this line from the
                  <span data-postcard-horizon>rapid MVP testing front</span>. Current vibe is
                  operating at
                  <span data-postcard-energy>58%</span>
                  intensity using a
                  <span data-postcard-collaboration>human-in-the-loop</span>
                  framework.
                </p>

                <div>
                  <p>Let's sync up on:</p>
                  <ul data-postcard-tags>
                    <li>-> AI STRATEGY</li>
                  </ul>
                </div>

                <p>
                  Catch you on the flip side,<br />
                  <span data-postcard-email>your-email@domain.com</span>
                </p>
              </div>
            </article>
          </section>
        </div>
      </section>

      <section class="grid gap-4">
        <section
          class="rounded-xl bg-white/90 p-5 shadow-[0_16px_42px_-34px_rgba(23,41,74,.42),0_0_4px_rgba(123,106,69,.18)] sm:p-6"
        >
          <div class="mb-5 flex items-end justify-between gap-4">
            <div>
              <p class="font-mono text-xs uppercase tracking-[0.08em] text-[var(--color-ink-dim)]">
                Strategy controls
              </p>
              <h2 class="mt-2 font-display text-4xl font-light leading-none sm:text-5xl">
                Tune the brief.
              </h2>
            </div>
            <span
              class="hidden rounded-full bg-[var(--color-bg-neutral)] px-3 py-2 font-mono text-[0.65rem] uppercase text-[var(--color-ink-dim)] sm:inline-flex"
              data-energy-badge
            >
              🤖 product mode
            </span>
          </div>

          <div class="grid gap-5">
            {
              vibeSliders.map((slider) => (
                <label class="grid gap-3">
                  <span class="flex items-center justify-between gap-3 font-mono text-xs uppercase text-[var(--color-ink-dim)]">
                    <span>{slider.label}</span>
                    <output data-slider-output={slider.key}>{slider.value}</output>
                  </span>
                  <input
                    class="vibe-slider"
                    type="range"
                    min="0"
                    max="100"
                    value={slider.value}
                    data-vibe-slider={slider.key}
                    aria-label={slider.label}
                  />
                  <span class="flex items-center justify-between gap-3 text-xs text-[var(--color-ink-dim)]">
                    <span>{slider.minLabel}</span>
                    <span class="h-px flex-1 bg-[color-mix(in_oklab,var(--color-ink)_12%,transparent)]" />
                    <span>{slider.maxLabel}</span>
                  </span>
                </label>
              ))
            }
          </div>
        </section>

        <section
          class="rounded-xl bg-white/90 p-5 shadow-[0_16px_42px_-34px_rgba(23,41,74,.42),0_0_4px_rgba(123,106,69,.18)] sm:p-6"
        >
          <p class="font-mono text-xs uppercase tracking-[0.08em] text-[var(--color-ink-dim)]">
            Click-to-inject chips
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {
              tags.map((tag, index) => (
                <button
                  type="button"
                  class="tag-pill rounded-full border border-[color-mix(in_oklab,var(--color-ink)_14%,transparent)] bg-[var(--color-bg-neutral)] px-4 py-2 font-mono text-xs uppercase text-[var(--color-ink)] transition duration-200 hover:-translate-y-1 hover:bg-[var(--color-orange-2)]"
                  data-tag={tag}
                  data-active={index === 0 ? "true" : "false"}
                  data-cursor="link"
                >
                  {tag}
                </button>
              ))
            }
          </div>
        </section>

        <section class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_minmax(220px,.55fr)]">
          <section
            class="rounded-xl bg-white/90 p-5 shadow-[0_16px_42px_-34px_rgba(23,41,74,.42),0_0_4px_rgba(123,106,69,.18)] sm:p-6"
            aria-labelledby="message-form-title"
          >
            <form action={formspreeEndpoint} method="POST" class="grid gap-4" data-connect-form>
              <input type="hidden" name="_subject" value="New portfolio postcard message" />
              <input type="hidden" name="postcard_summary" data-generated-message />

              <div>
                <p
                  class="font-mono text-xs uppercase tracking-[0.08em] text-[var(--color-ink-dim)]"
                >
                  Message Form
                </p>
                <h2
                  id="message-form-title"
                  class="mt-2 font-display text-4xl font-light leading-none"
                >
                  Send the postcard.
                </h2>
              </div>

              <label class="grid gap-2">
                <span class="font-mono text-xs uppercase text-[var(--color-ink-dim)]"
                  >Full Name</span
                >
                <input
                  class="rounded-xl border-0 bg-[var(--color-bg-neutral)] px-4 py-3 text-[var(--color-ink)] outline-none placeholder:text-[var(--color-ink-mute)] focus:shadow-[0_0_0_3px_color-mix(in_oklab,var(--color-orange)_18%,transparent)]"
                  name="name"
                  type="text"
                  autocomplete="name"
                  placeholder="Someone Awesome"
                  data-name-input
                  required
                />
              </label>

              <label class="grid gap-2">
                <span class="font-mono text-xs uppercase text-[var(--color-ink-dim)]">
                  Email Address
                </span>
                <input
                  class="rounded-xl border-0 bg-[var(--color-bg-neutral)] px-4 py-3 text-[var(--color-ink)] outline-none placeholder:text-[var(--color-ink-mute)] focus:shadow-[0_0_0_3px_color-mix(in_oklab,var(--color-orange)_18%,transparent)]"
                  name="email"
                  type="email"
                  autocomplete="email"
                  placeholder="your-email@domain.com"
                  data-email-input
                  required
                />
              </label>

              <label class="grid gap-2">
                <span class="font-mono text-xs uppercase text-[var(--color-ink-dim)]">Message</span>
                <textarea
                  class="min-h-28 resize-y rounded-xl border-0 bg-[var(--color-bg-neutral)] px-4 py-3 text-[var(--color-ink)] outline-none placeholder:text-[var(--color-ink-mute)] focus:shadow-[0_0_0_3px_color-mix(in_oklab,var(--color-orange)_18%,transparent)]"
                  name="message"
                  placeholder="Let's build something useful. Put your thoughts here..."
                  data-message-input
                  required></textarea>
              </label>

              <div class="relative">
                <div
                  class="particle-layer pointer-events-none absolute inset-0 overflow-visible"
                  aria-hidden="true"
                  data-particle-layer
                >
                </div>
                <button
                  type="submit"
                  class="w-full rounded-2xl border-0 border-b-4 border-neutral-700 bg-[var(--color-orange)] px-6 py-5 font-mono text-base uppercase tracking-[0.08em] text-[var(--color-ink)] shadow-[0_18px_34px_-24px_rgba(36,36,36,.85)] transition duration-150 hover:-translate-y-1 hover:bg-[var(--color-orange-1)] active:translate-y-1 active:border-b-0 sm:text-lg"
                  data-send-button
                  data-cursor="link"
                >
                  Send message
                </button>
              </div>

              <p
                class="min-h-6 text-center font-mono text-xs uppercase text-[var(--color-ink-dim)]"
                data-form-status
              >
                Ready when you are.
              </p>
            </form>
          </section>

          <nav
            class="rounded-xl bg-[var(--color-ink)] p-5 text-[var(--color-ink-inverted)] shadow-[0_16px_42px_-34px_rgba(23,41,74,.42),0_0_4px_rgba(123,106,69,.18)] sm:p-6"
            aria-label="Direct Channels"
          >
            <p class="font-mono text-xs uppercase tracking-[0.08em] text-[var(--color-starlight)]">
              Direct Channels
            </p>
            <div class="mt-5 grid gap-3">
              {
                channels.map((channel) => (
                  <a
                    href={channel.href}
                    class="group grid gap-1 rounded-lg bg-white/8 p-4 text-inherit no-underline transition duration-200 hover:-translate-y-1 hover:bg-white/14"
                    data-cursor="link"
                  >
                    <span class="font-display text-2xl font-light leading-none">
                      {channel.label}
                    </span>
                    <small class="font-mono text-[0.68rem] uppercase text-[var(--color-starlight)]">
                      {channel.note}
                    </small>
                  </a>
                ))
              }
            </div>
          </nav>
        </section>
      </section>
    </main>
  </div>

  <CustomCursor color="orange" />
</BaseLayout>

<style>
  .postcard-wrap {
    border-radius: 18px;
    padding: clamp(10px, 2vw, 18px);
    background:
      linear-gradient(135deg, color-mix(in oklab, var(--color-teal) 18%, white), transparent 58%),
      var(--color-bg-neutral);
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 9%, transparent);
  }

  .postcard {
    position: relative;
    display: grid;
    gap: 16px;
    min-height: 390px;
    border: 2px solid color-mix(in oklab, var(--color-ink) 62%, transparent);
    border-radius: 14px;
    padding: clamp(18px, 3vw, 30px);
    background:
      linear-gradient(
        90deg,
        transparent calc(100% - 132px),
        color-mix(in oklab, var(--color-ink) 8%, transparent) calc(100% - 131px),
        transparent calc(100% - 130px)
      ),
      radial-gradient(circle at 20% 10%, rgba(255, 255, 255, 0.78), transparent 180px), #fffdf4;
    color: var(--color-ink);
    font-family: var(--font-mono);
  }

  .postcard::before {
    content: "";
    position: absolute;
    inset: 10px;
    border: 1px dashed color-mix(in oklab, var(--color-ink) 24%, transparent);
    border-radius: 10px;
    pointer-events: none;
  }

  .postcard__meta {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 16px;
    align-items: start;
  }

  .postcard__meta p,
  .postcard__to,
  .postcard__body p,
  .postcard__body ul {
    margin: 0;
  }

  .postcard__meta span,
  .postcard__body span {
    color: var(--color-teal);
  }

  .postcard__stamp {
    display: grid;
    place-items: center;
    width: 92px;
    min-height: 86px;
    border: 2px solid color-mix(in oklab, var(--color-ink) 52%, transparent);
    border-radius: 8px;
    transform: rotate(2deg);
  }

  .postcard__stamp span {
    color: var(--color-ink-dim);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
  }

  .postcard__stamp strong {
    font-size: 2rem;
    line-height: 1;
  }

  .postcard__to,
  .postcard__body {
    position: relative;
    z-index: 1;
  }

  .postcard__body {
    display: grid;
    gap: 18px;
    max-width: 72ch;
    line-height: 1.55;
  }

  .postcard__body ul {
    display: grid;
    gap: 3px;
    padding: 0;
    list-style: none;
  }

  .vibe-slider {
    width: 100%;
    height: 12px;
    appearance: none;
    border-radius: 999px;
    background:
      linear-gradient(
        90deg,
        var(--color-orange) var(--slider-fill, 50%),
        var(--color-bg-neutral) 0
      ),
      var(--color-bg-neutral);
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 12%, transparent);
    cursor: pointer;
  }

  .vibe-slider::-webkit-slider-thumb {
    width: 28px;
    height: 28px;
    appearance: none;
    border: 3px solid var(--color-ink);
    border-radius: 999px;
    background: var(--color-bg-light);
    box-shadow: 0 10px 18px -12px rgba(36, 36, 36, 0.78);
  }

  .vibe-slider::-moz-range-thumb {
    width: 24px;
    height: 24px;
    border: 3px solid var(--color-ink);
    border-radius: 999px;
    background: var(--color-bg-light);
    box-shadow: 0 10px 18px -12px rgba(36, 36, 36, 0.78);
  }

  .tag-pill[data-active="true"] {
    border-color: var(--color-ink);
    background: var(--color-teal);
    color: var(--color-ink-inverted);
    transform: translateY(-2px);
  }

  .particle {
    position: absolute;
    left: 50%;
    bottom: 18px;
    font-size: 1.45rem;
    animation: particle-pop 760ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    transform: translate(-50%, 0);
  }

  @keyframes particle-pop {
    to {
      opacity: 0;
      transform: translate(calc(-50% + var(--x)), var(--y)) rotate(var(--r)) scale(0.4);
    }
  }

  @media (max-width: 640px) {
    .postcard {
      min-height: 0;
      background: #fffdf4;
    }

    .postcard__meta {
      grid-template-columns: 1fr;
    }

    .postcard__stamp {
      justify-self: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tag-pill,
    .particle,
    [data-send-button] {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  function initConnectPlayground() {
    const rootCandidate = document.querySelector<HTMLElement>("[data-connect-playground]");
    if (!rootCandidate || rootCandidate.dataset.connectWired === "1") return;
    const root = rootCandidate;
    root.dataset.connectWired = "1";

    const nameInput = root.querySelector<HTMLInputElement>("[data-name-input]");
    const emailInput = root.querySelector<HTMLInputElement>("[data-email-input]");
    const messageInput = root.querySelector<HTMLTextAreaElement>("[data-message-input]");
    const postcardName = root.querySelector<HTMLElement>("[data-postcard-name]");
    const postcardEmail = root.querySelector<HTMLElement>("[data-postcard-email]");
    const postcardHorizon = root.querySelector<HTMLElement>("[data-postcard-horizon]");
    const postcardEnergy = root.querySelector<HTMLElement>("[data-postcard-energy]");
    const postcardCollaboration = root.querySelector<HTMLElement>("[data-postcard-collaboration]");
    const postcardStamp = root.querySelector<HTMLElement>("[data-postcard-stamp]");
    const postcardTags = root.querySelector<HTMLElement>("[data-postcard-tags]");
    const energyBadge = root.querySelector<HTMLElement>("[data-energy-badge]");
    const hiddenMessage = root.querySelector<HTMLInputElement>("[data-generated-message]");
    const status = root.querySelector<HTMLElement>("[data-form-status]");
    const sendButton = root.querySelector<HTMLButtonElement>("[data-send-button]");
    const particleLayer = root.querySelector<HTMLElement>("[data-particle-layer]");
    const form = root.querySelector<HTMLFormElement>("[data-connect-form]");
    const activeTags = new Set<string>();

    root.querySelectorAll<HTMLButtonElement>("[data-tag]").forEach((button) => {
      if (button.dataset.active === "true" && button.dataset.tag)
        activeTags.add(button.dataset.tag);
    });

    function readSlider(key: string) {
      const input = root.querySelector<HTMLInputElement>(`[data-vibe-slider="${key}"]`);
      return Number(input?.value ?? 50);
    }

    function horizonText(value: number) {
      return value < 50 ? "rapid MVP testing front" : "deep AI transformation front";
    }

    function collaborationText(value: number) {
      if (value < 34) return "human-in-the-loop";
      if (value < 67) return "AI-assisted product ops";
      return "pure automation";
    }

    function energyStamp(value: number) {
      if (value < 34) return "☕";
      if (value < 72) return "🤖";
      return "🚀";
    }

    function renderTags() {
      if (!postcardTags) return;
      postcardTags.replaceChildren();
      const tags = Array.from(activeTags);
      const visibleTags = tags.length ? tags : ["AI STRATEGY"];
      visibleTags.forEach((tag) => {
        const li = document.createElement("li");
        li.textContent = `-> ${tag}`;
        postcardTags.append(li);
      });
    }

    function postcardText() {
      const name = nameInput?.value.trim() || "Someone Awesome";
      const email = emailInput?.value.trim() || "your-email@domain.com";
      const horizon = horizonText(readSlider("horizon"));
      const energy = readSlider("energy");
      const collaboration = collaborationText(readSlider("collaboration"));
      const tags = Array.from(activeTags).join(", ") || "AI STRATEGY";
      const note = messageInput?.value.trim();
      return [
        `POSTCARD FROM: ${name}`,
        "TO: Aishwarya Chourasia",
        `Hello Aishwarya, I'm dropping this line from the ${horizon}.`,
        `Current vibe is operating at ${energy}% intensity using a ${collaboration} framework.`,
        `Let's sync up on: ${tags}.`,
        note ? `Message: ${note}` : "",
        `Catch you on the flip side, ${email}`,
      ]
        .filter(Boolean)
        .join("\n");
    }

    function syncPreview() {
      const name = nameInput?.value.trim() || "Someone Awesome";
      const email = emailInput?.value.trim() || "your-email@domain.com";
      const horizon = readSlider("horizon");
      const energy = readSlider("energy");
      const collaboration = readSlider("collaboration");
      const stamp = energyStamp(energy);

      if (postcardName) postcardName.textContent = name;
      if (postcardEmail) postcardEmail.textContent = email;
      if (postcardHorizon) postcardHorizon.textContent = horizonText(horizon);
      if (postcardEnergy) postcardEnergy.textContent = `${energy}%`;
      if (postcardCollaboration)
        postcardCollaboration.textContent = collaborationText(collaboration);
      if (postcardStamp) postcardStamp.textContent = stamp;
      if (energyBadge) energyBadge.textContent = `${stamp} product mode`;
      if (hiddenMessage) hiddenMessage.value = postcardText();
      renderTags();
    }

    root.querySelectorAll<HTMLInputElement>("[data-vibe-slider]").forEach((slider) => {
      const output = root.querySelector<HTMLOutputElement>(
        `[data-slider-output="${slider.dataset.vibeSlider}"]`,
      );

      function updateSlider() {
        slider.style.setProperty("--slider-fill", `${slider.value}%`);
        if (output) output.value = slider.value;
        syncPreview();
      }

      slider.addEventListener("input", updateSlider);
      updateSlider();
    });

    [nameInput, emailInput, messageInput].forEach((input) => {
      input?.addEventListener("input", syncPreview);
    });

    root.querySelectorAll<HTMLButtonElement>("[data-tag]").forEach((button) => {
      button.addEventListener("click", () => {
        const tag = button.dataset.tag ?? "";
        if (activeTags.has(tag)) activeTags.delete(tag);
        else activeTags.add(tag);
        button.dataset.active = activeTags.has(tag) ? "true" : "false";
        syncPreview();
      });
    });

    function burst() {
      if (!particleLayer) return;
      const particles = ["🚀", "⚡", "✨", "🎉", "🤖", "💡"];
      particleLayer.replaceChildren();
      particles.forEach((particle, index) => {
        const span = document.createElement("span");
        span.className = "particle";
        span.textContent = particle;
        span.style.setProperty("--x", `${(index - 2.5) * 42}px`);
        span.style.setProperty("--y", `${-70 - (index % 3) * 28}px`);
        span.style.setProperty("--r", `${-28 + index * 11}deg`);
        particleLayer.append(span);
      });
      window.setTimeout(() => particleLayer.replaceChildren(), 900);
    }

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      syncPreview();
      burst();
      if (sendButton) sendButton.textContent = "Message Transmitted! 🎉";
      if (status) status.textContent = "Transmission staged. Your postcard is ready.";

      const action = form.getAttribute("action") ?? "";
      if (!action.includes("your-form-id")) {
        try {
          const response = await fetch(action, {
            method: "POST",
            body: new FormData(form),
            headers: { Accept: "application/json" },
          });
          if (!response.ok) throw new Error("Submit failed");
          if (status) status.textContent = "Message sent. Postcard delivered.";
          form.reset();
          activeTags.clear();
          root.querySelectorAll<HTMLButtonElement>("[data-tag]").forEach((button) => {
            button.dataset.active = "false";
          });
          syncPreview();
        } catch {
          if (status) status.textContent = "Could not send yet. Check the form endpoint.";
        }
      }

      window.setTimeout(() => {
        if (sendButton) sendButton.textContent = "Send message";
      }, 2200);
    });

    syncPreview();
  }

  initConnectPlayground();
  document.addEventListener("astro:page-load", initConnectPlayground);
</script>
