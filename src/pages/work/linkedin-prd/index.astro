---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { withBase } from "../../../lib/paths";
---

<BaseLayout
  title="LinkedIn Connection Lens PRD - Aishwarya's Portfolio"
  description="Connection Lens is a lightweight LinkedIn-themed product requirements document for reliable first-degree connection search."
>
  <main class="framed-project">
    <iframe
      src={withBase("/allprojects/linkedin-prd/index.html")}
      title="LinkedIn Connection Lens PRD"
    ></iframe>
  </main>
</BaseLayout>

<style>
  .framed-project {
    min-height: 100vh;
    background: var(--color-bg);
  }

  iframe {
    display: block;
    width: 100%;
    height: 100vh;
    border: 0;
    background: #f3f2ef;
  }

  @media (max-width: 980px) {
    .framed-project {
      grid-template-columns: 1fr;
    }
  }
</style>
