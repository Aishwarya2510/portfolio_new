---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { withBase } from "../../../lib/paths";
---

<BaseLayout
  title="Duolingo Growth Experiment - Aishwarya's Portfolio"
  description="Project Momentum is a Duolingo D7 retention growth experiment case study."
>
  <main class="framed-project">
    <iframe
      src={withBase("/allprojects/duolingo_growth_experiment/index.html")}
      title="Duolingo Growth Experiment case study"
    ></iframe>
  </main>
</BaseLayout>

<style>
  .framed-project {
    min-height: 100vh;
    background: var(--color-bg);
  }

  iframe {
    display: block;
    width: 100%;
    height: 100vh;
    border: 0;
    background: #07130d;
  }

  @media (max-width: 980px) {
    .framed-project {
      grid-template-columns: 1fr;
    }
  }
</style>
