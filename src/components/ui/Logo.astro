---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<span class:list={["logo-mark", className]} aria-hidden="true">
  <span>A</span>
</span>

<style>
  .logo-mark {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 12px;
    background:
      radial-gradient(circle at 72% 22%, #ffd79d 0 16%, transparent 17%),
      linear-gradient(135deg, var(--color-orange-1), var(--color-pink-1));
    box-shadow:
      inset 0 0 0 1px rgba(59, 39, 29, 0.12),
      0 8px 18px -14px rgba(89, 48, 19, 0.55);
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 1.45rem;
    line-height: 1;
  }

  .logo-mark span {
    transform: translateY(-1px);
  }
</style>
