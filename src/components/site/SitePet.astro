  }

  .monster-switcher__trigger {
    display: grid;
    place-items: center;
    width: 42px;
    min-height: 42px;
    overflow: hidden;
    padding: 0;
    color: transparent;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition:
      transform 180ms cubic-bezier(0.22, 1, 0.36, 1),
      background 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .monster-switcher__trigger:hover,
  .monster-switcher__trigger:focus-visible {
    transform: translateY(-1px);
    background: #f3f1eb;
  }

  .monster-switcher__trigger::before {
    content: "";
