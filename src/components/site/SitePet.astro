    width: 18px;
    height: 18px;
    border: 2px solid #dacc9d;
    border-radius: 999px;
    background: #b8ffe7;
    box-shadow: inset 0 -4px 0 rgba(0, 0, 0, 0.14);
  }

  .monster-switcher__panel {
    position: absolute;
    right: 0;
    bottom: calc(100% + 8px);
    width: min(286px, calc(100vw - 32px));
    padding: 10px;
    border: 1px solid rgba(36, 36, 36, 0.16);
    border-radius: 8px;
    background: rgba(243, 241, 235, 0.96);
    box-shadow: 0 18px 44px -24px rgba(0, 0, 0, 0.62);
