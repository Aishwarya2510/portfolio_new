---
/*
  SitePet — a tiny blocky creature that walks along the bottom of the
  viewport, bouncing off the right edge of the sidebar like a wall.
  Reserved ink palette; no blush / hearts.

  Behavior:
    • Walks left/right. Right edge of the sidebar + right edge of the
      viewport act as walls; on collision it reverses and posts a speech
      bubble ("ow!" etc).
    • Draggable: pointerdown on the body grabs the pet; pointermove drags
      it anywhere (clamped so it stays on screen); pointerup drops it and
      it resumes walking from wherever it lands.
    • Click → hop + blink + fun quip.
    • Speech bubbles: translucent ink with cream mono text, fade in/out.
    • `transition:persist` so the pet keeps position + state across SPA
      navigations. Respects prefers-reduced-motion.
*/
---

<div data-site-pet transition:persist="site-pet" aria-hidden="true" class="site-pet">
  <div class="site-pet__bubble" data-pet-bubble aria-hidden="true"></div>
  <div class="site-pet__emotes" data-pet-emotes aria-hidden="true"></div>
  <button
    type="button"
    data-pet-hit
    data-cursor="link"
    class="site-pet__hit"
    aria-label="Pet the pet"
  >
    <span class="site-pet__bob">
      <svg width="44" height="56" viewBox="0 0 44 56" class="site-pet__svg" fill="none">
        <!-- soft contact shadow so the pet reads as grounded -->
        <ellipse
          class="site-pet__shadow"
          cx="22"
          cy="53.5"
          rx="14"
          ry="1.8"
          fill="#242424"
          opacity="0.16"></ellipse>

        <!-- monster body: colors and extras are driven by data-monster. -->
        <g class="site-pet__monster-extra" data-monster-extra="spark">
          <path d="M6 10L13 1L14 10Z" fill="var(--monster-accent)"></path>
          <path d="M31 10L38 1L39 10Z" fill="var(--monster-accent)"></path>
        </g>
        <g class="site-pet__monster-extra" data-monster-extra="moss">
          <ellipse cx="13" cy="6" rx="8" ry="4" fill="var(--monster-accent)" transform="rotate(24 13 6)"></ellipse>
          <ellipse cx="31" cy="6" rx="8" ry="4" fill="var(--monster-accent)" transform="rotate(-24 31 6)"></ellipse>
        </g>
        <g class="site-pet__monster-extra" data-monster-extra="orbit">
          <ellipse cx="22" cy="28" rx="23" ry="9" stroke="var(--monster-accent)" stroke-width="2" opacity="0.7"></ellipse>
        </g>
        <g class="site-pet__monster-extra" data-monster-extra="byte">
          <rect x="3" y="15" width="7" height="7" rx="1.5" fill="var(--monster-accent)"></rect>
          <rect x="34" y="15" width="7" height="7" rx="1.5" fill="var(--monster-accent)"></rect>
        </g>
        <g class="site-pet__monster-extra" data-monster-extra="bloom">
          <circle cx="22" cy="5" r="4" fill="var(--monster-accent)"></circle>
          <circle cx="16" cy="8" r="4" fill="var(--monster-accent)"></circle>
          <circle cx="28" cy="8" r="4" fill="var(--monster-accent)"></circle>
        </g>
        <g class="site-pet__monster-extra" data-monster-extra="ember">
          <path d="M22 -1C30 7 25 12 22 15C17 10 18 5 22 -1Z" fill="var(--monster-accent)"></path>
        </g>
        <g class="site-pet__monster-extra" data-monster-extra="luna">
          <path d="M31 1C25 3 23 10 27 15C20 13 17 5 22 0C25 -3 29 -2 31 1Z" fill="var(--monster-accent)"></path>
        </g>
        <g class="site-pet__monster-extra" data-monster-extra="prism">
          <polygon points="22,0 29,11 22,16 15,11" fill="var(--monster-accent)"></polygon>
        </g>
        <g class="site-pet__monster-extra" data-monster-extra="reef">
          <path d="M5 17C0 13 0 7 6 5C10 8 10 14 5 17Z" fill="var(--monster-accent)"></path>
          <path d="M39 17C44 13 44 7 38 5C34 8 34 14 39 17Z" fill="var(--monster-accent)"></path>
        </g>
        <g class="site-pet__monster-extra" data-monster-extra="nova">
          <path d="M22 -1L24.5 6L32 6.5L26 11L28 18L22 14L16 18L18 11L12 6.5L19.5 6Z" fill="var(--monster-accent)"></path>
        </g>
        <circle class="site-pet__ear" cx="10" cy="15" r="5.2" fill="var(--monster-accent)"></circle>
        <circle class="site-pet__ear" cx="34" cy="15" r="5.2" fill="var(--monster-accent)"></circle>
        <rect class="site-pet__body" x="5" y="10" width="34" height="35" rx="13" fill="var(--monster-body)"></rect>
        <rect x="9" y="13" width="26" height="5" rx="2.5" fill="#f3f1eb" opacity="0.28"></rect>
        <circle cx="13.5" cy="31" r="3" fill="var(--monster-blush)" opacity="0.95"></circle>
        <circle cx="30.5" cy="31" r="3" fill="var(--monster-blush)" opacity="0.95"></circle>

        <!-- button eyes — grouped so blink + glance behavior still works. -->
        <g class="site-pet__eyes" style="--eye-x: 0; --eye-y: 0;">
          <rect class="site-pet__eye" x="14" y="24" width="4.5" height="5.5" rx="2.25" fill="var(--monster-ink)"
          ></rect>
          <rect class="site-pet__eye" x="25.5" y="24" width="4.5" height="5.5" rx="2.25" fill="var(--monster-ink)"
          ></rect>
        </g>
        <path
          d="M19 33.5C20.1 35 23.9 35 25 33.5"
          stroke="var(--monster-ink)"
          stroke-width="1.7"
          stroke-linecap="round"></path>

        <!-- tiny feet — keep the existing leg classes so the walk cycle works. -->
        <rect
          class="site-pet__leg site-pet__leg--left"
          x="11"
          y="42"
          width="7"
          height="9"
          rx="3.5"
          fill="var(--monster-foot)"></rect>
        <rect
          class="site-pet__leg site-pet__leg--right"
          x="26"
          y="42"
          width="7"
          height="9"
          rx="3.5"
          fill="var(--monster-foot)"></rect>
      </svg>
    </span>
  </button>
</div>

<div class="monster-switcher" data-monster-switcher>
  <button
    type="button"
    class="monster-switcher__trigger"
    data-monster-switcher-trigger
    data-cursor="link"
    aria-expanded="false"
    aria-controls="monster-switcher-panel"
  >
    Change monster
  </button>
  <div
    id="monster-switcher-panel"
    class="monster-switcher__panel"
    data-monster-switcher-panel
    hidden
  >
    <div class="monster-switcher__grid" aria-label="Choose monster">
      <button type="button" class="monster-switcher__choice" data-monster-switch-choice="spark" style="--swatch-body:#b8ffe7;--swatch-accent:#ffeb6e;">Spark</button>
      <button type="button" class="monster-switcher__choice" data-monster-switch-choice="moss" style="--swatch-body:#7db592;--swatch-accent:#d7f27a;">Moss</button>
      <button type="button" class="monster-switcher__choice" data-monster-switch-choice="orbit" style="--swatch-body:#9fa8ff;--swatch-accent:#73f3ff;">Orbit</button>
      <button type="button" class="monster-switcher__choice" data-monster-switch-choice="byte" style="--swatch-body:#8ad7ff;--swatch-accent:#ff7bd3;">Byte</button>
      <button type="button" class="monster-switcher__choice" data-monster-switch-choice="bloom" style="--swatch-body:#ff9bd0;--swatch-accent:#ffe16b;">Bloom</button>
      <button type="button" class="monster-switcher__choice" data-monster-switch-choice="ember" style="--swatch-body:#ff955c;--swatch-accent:#ffd36a;">Ember</button>
      <button type="button" class="monster-switcher__choice" data-monster-switch-choice="luna" style="--swatch-body:#d9e3ff;--swatch-accent:#9bb4ff;">Luna</button>
      <button type="button" class="monster-switcher__choice" data-monster-switch-choice="prism" style="--swatch-body:#f3c8ff;--swatch-accent:#77ffd8;">Prism</button>
      <button type="button" class="monster-switcher__choice" data-monster-switch-choice="reef" style="--swatch-body:#65d6c7;--swatch-accent:#6ee7ff;">Reef</button>
      <button type="button" class="monster-switcher__choice" data-monster-switch-choice="nova" style="--swatch-body:#f8f1b5;--swatch-accent:#ff8ab3;">Nova</button>
    </div>
  </div>
</div>

<style is:global>
  .site-pet {
    position: fixed;
    left: 0;
    bottom: 0;
    z-index: 80;
    pointer-events: none;
    --pet-x: 40px;
    --pet-y: 0px;
    --pet-ground: 0px;
    --pet-flip: 1;
    --monster-body: #76aab2;
    --monster-accent: #65b6c3;
    --monster-foot: #168b9d;
    --monster-blush: #eabaca;
    --monster-ink: #242424;
    --pet-scale: 1;
    transform: translate3d(var(--pet-x), calc((var(--pet-y) + var(--pet-ground)) * -1), 0) scale(var(--pet-scale));
    transform-origin: 50% 100%;
    will-change: transform;
  }
  .site-pet[data-monster="spark"] {
    --monster-body: #b8ffe7;
    --monster-accent: #ffeb6e;
    --monster-foot: #18bfa8;
    --monster-blush: #ff9bd0;
    --monster-ink: #06100f;
  }
  .site-pet[data-monster="moss"] {
    --monster-body: #7db592;
    --monster-accent: #d7f27a;
    --monster-foot: #2f7f4e;
    --monster-blush: #f3d4a8;
  }
  .site-pet[data-monster="orbit"] {
    --monster-body: #9fa8ff;
    --monster-accent: #73f3ff;
    --monster-foot: #5b66d9;
    --monster-blush: #ffc2ed;
  }
  .site-pet[data-monster="byte"] {
    --monster-body: #8ad7ff;
    --monster-accent: #ff7bd3;
    --monster-foot: #3177b8;
    --monster-blush: #c9ff7d;
  }
  .site-pet[data-monster="bloom"] {
    --monster-body: #ff9bd0;
    --monster-accent: #ffe16b;
    --monster-foot: #bf5a7a;
    --monster-blush: #ffffff;
  }
  .site-pet[data-monster="ember"] {
    --monster-body: #ff955c;
    --monster-accent: #ffd36a;
    --monster-foot: #bc4e2f;
    --monster-blush: #ffe1a8;
  }
  .site-pet[data-monster="luna"] {
    --monster-body: #d9e3ff;
    --monster-accent: #9bb4ff;
    --monster-foot: #8293d8;
    --monster-blush: #c4fff2;
  }
  .site-pet[data-monster="prism"] {
    --monster-body: #f3c8ff;
    --monster-accent: #77ffd8;
    --monster-foot: #b66fd0;
    --monster-blush: #fff18a;
  }
  .site-pet[data-monster="reef"] {
    --monster-body: #65d6c7;
    --monster-accent: #6ee7ff;
    --monster-foot: #168b9d;
    --monster-blush: #ffd0ad;
  }
  .site-pet[data-monster="nova"] {
    --monster-body: #f8f1b5;
    --monster-accent: #ff8ab3;
    --monster-foot: #c8951a;
    --monster-blush: #a7f3ff;
  }
  .site-pet[data-contact-page] {
    --pet-scale: 1.42;
  }
  .site-pet[data-contact-page] .site-pet__bubble {
    bottom: 78px;
    min-width: 126px;
    background: rgba(59, 39, 29, 0.9);
  }
  .site-pet__monster-extra {
    display: none;
  }
  .site-pet[data-monster="spark"] [data-monster-extra="spark"],
  .site-pet[data-monster="moss"] [data-monster-extra="moss"],
  .site-pet[data-monster="orbit"] [data-monster-extra="orbit"],
  .site-pet[data-monster="byte"] [data-monster-extra="byte"],
  .site-pet[data-monster="bloom"] [data-monster-extra="bloom"],
  .site-pet[data-monster="ember"] [data-monster-extra="ember"],
  .site-pet[data-monster="luna"] [data-monster-extra="luna"],
  .site-pet[data-monster="prism"] [data-monster-extra="prism"],
  .site-pet[data-monster="reef"] [data-monster-extra="reef"],
  .site-pet[data-monster="nova"] [data-monster-extra="nova"] {
    display: block;
  }
  .site-pet__hit {
    display: block;
    position: relative;
    /* Extra hit slop so taps don't miss and pass through to cards below */
    padding: 12px;
    margin: -12px;
    border: 0;
    background: transparent;
    cursor: grab;
    pointer-events: auto;
    transform: scaleX(var(--pet-flip));
    transform-origin: 50% 50%;
    transition: transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
    touch-action: none;
  }
  .site-pet[data-dragging] .site-pet__hit {
    cursor: grabbing;
  }
  .site-pet[data-on-clickable] .site-pet__hit {
    padding: 20px;
    margin: -20px;
  }
  .site-pet__svg {
    display: block;
  }

  /* Whole-body idle bob - disabled while hopping or being dragged. */
  .site-pet__bob {
    display: block;
    animation: site-pet-bob 0.5s ease-in-out infinite;
  }
  @keyframes site-pet-bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-1.5px);
    }
  }

  /* Walk cycle — legs alternate in a crisp 2-step cadence. */
  .site-pet__leg {
    transform-origin: 50% 100%;
    animation: site-pet-leg 0.46s steps(2, end) infinite;
  }
  .site-pet__leg--right {
    animation-delay: 0.23s;
  }
  @keyframes site-pet-leg {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-3px);
    }
  }

  /* Blink. */
  .site-pet__eye {
    transform-origin: 50% 50%;
    transition: transform 120ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .site-pet[data-blink] .site-pet__eye {
    transform: scaleY(0.15);
  }

  /* Pause walking when hovered. (Drag has its own leg animation, below.) */
  .site-pet[data-paused]:not([data-dragging]) .site-pet__leg,
  .site-pet[data-paused]:not([data-dragging]) .site-pet__bob {
    animation-play-state: paused;
  }

  /* Dragged: legs kick and flail as the pet is hoisted into the air. */
  .site-pet[data-dragging] .site-pet__bob {
    animation: none;
  }
  .site-pet[data-dragging] .site-pet__leg {
    animation: site-pet-leg-kick 0.26s ease-in-out infinite;
    transform-origin: 50% 0%;
  }
  .site-pet[data-dragging] .site-pet__leg--right {
    animation-delay: 0.13s;
  }
  @keyframes site-pet-leg-kick {
    0% {
      transform: translateY(1px) rotate(-16deg);
    }
    50% {
      transform: translateY(-1px) rotate(14deg);
    }
    100% {
      transform: translateY(1px) rotate(-16deg);
    }
  }

  /* Shadow shrinks while airborne (dragged or hopping) so the pet reads as
     lifted off the ground. */
  .site-pet__shadow {
    transition:
      opacity 180ms ease-out,
      transform 180ms ease-out;
    transform-origin: 22px 53.5px;
  }
  .site-pet[data-dragging] .site-pet__shadow {
    opacity: 0.08;
    transform: scale(0.7);
  }

  .site-pet[data-rocket] .site-pet__bob {
    animation: site-pet-rocket-wiggle 0.22s ease-in-out infinite;
  }

  .site-pet[data-rocket] .site-pet__leg {
    animation-duration: 0.12s;
  }

  .site-pet[data-rocket] .site-pet__shadow {
    opacity: 0.04;
    transform: scale(0.45);
  }

  .site-pet[data-angry] .site-pet__bob {
    animation: site-pet-angry-shake 0.16s linear infinite;
  }

  .site-pet[data-angry] .site-pet__body {
    fill: #ff6f6f;
  }

  .site-pet[data-angry] .site-pet__eye {
    transform: scaleY(0.45);
  }

  @keyframes site-pet-rocket-wiggle {
    0%,
    100% {
      transform: translateY(0) rotate(-8deg);
    }
    50% {
      transform: translateY(-5px) rotate(8deg);
    }
  }

  @keyframes site-pet-angry-shake {
    0%,
    100% {
      transform: translateX(-1px) rotate(-2deg);
    }
    50% {
      transform: translateX(1px) rotate(2deg);
    }
  }

  /* Lean on bump — quick squash + rotate when hitting a wall. */
  .site-pet[data-bump] .site-pet__bob {
    animation: site-pet-bump 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes site-pet-bump {
    0% {
      transform: translateX(0) rotate(0deg);
    }
    30% {
      transform: translateX(calc(var(--pet-bump-dir, 1) * 3px))
        rotate(calc(var(--pet-bump-dir, 1) * -6deg));
    }
    100% {
      transform: translateX(0) rotate(0deg);
    }
  }

  /* Hop on click. */
  .site-pet[data-hopping] .site-pet__bob {
    animation: site-pet-hop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes site-pet-hop {
    0% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(-18px) rotate(-6deg);
    }
    100% {
      transform: translateY(0);
    }
  }

  /* Dizzy — shaken hard while being dragged. Pet holds still, eyes swirl,
     little sparks orbit, speech reads "whoaa....". */
  .site-pet[data-dizzy] .site-pet__bob {
    animation: site-pet-dizzy-sway 0.6s ease-in-out infinite;
  }
  .site-pet[data-dizzy] .site-pet__eyes {
    animation: site-pet-dizzy-eyes 0.9s linear infinite;
    transform-origin: 22px 25px;
  }
  .site-pet[data-dizzy] .site-pet__leg {
    animation-play-state: paused;
  }
  @keyframes site-pet-dizzy-sway {
    0%,
    100% {
      transform: rotate(-4deg);
    }
    50% {
      transform: rotate(4deg);
    }
  }
  @keyframes site-pet-dizzy-eyes {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  /* Orbiting dizzy stars layered above the pet. */
  .site-pet-spin-star {
    position: absolute;
    left: 50%;
    top: 4px;
    width: 4px;
    height: 4px;
    border-radius: 9999px;
    background: #f3e9d6;
    box-shadow: 0 0 4px rgba(243, 233, 214, 0.65);
    transform: translate(-50%, -50%);
    animation: site-pet-spin-star 0.9s linear infinite;
  }
  @keyframes site-pet-spin-star {
    from {
      transform: translate(-50%, -50%) rotate(0deg) translateX(18px) rotate(0deg);
    }
    to {
      transform: translate(-50%, -50%) rotate(360deg) translateX(18px) rotate(-360deg);
    }
  }

  /*
    Swirl trails — rendered every time the pet is shaken, before dizzy
    fully kicks in. Open-ring SVGs spiral upward and fade, giving
    immediate visual feedback that shaking means something.
  */
  .site-pet-swirl {
    position: absolute;
    left: 50%;
    top: 6px;
    width: 12px;
    height: 12px;
    pointer-events: none;
    transform: translate(-50%, -50%);
    opacity: 0;
    color: #f3e9d6;
    animation: site-pet-swirl 0.95s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .site-pet-swirl svg {
    display: block;
  }
  @keyframes site-pet-swirl {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) rotate(0deg) scale(0.5);
    }
    30% {
      opacity: 0.95;
    }
    100% {
      opacity: 0;
      transform: translate(calc(-50% + var(--swirl-dx, 0px)), calc(-50% - 34px)) rotate(540deg)
        scale(1.15);
    }
  }

  /* Emote layer — a single discreet ink dot rises from the head on click. */
  .site-pet__emotes {
    position: absolute;
    left: 50%;
    top: 2px;
    width: 0;
    height: 0;
    pointer-events: none;
  }
  .site-pet-emote {
    position: absolute;
    left: 0;
    top: 0;
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: #242424;
    transform: translate(-50%, -50%);
    opacity: 0;
    animation: site-pet-emote 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes site-pet-emote {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.4);
    }
    25% {
      opacity: 0.75;
      transform: translate(calc(-50% + var(--emote-dx, 0px)), calc(-50% - 10px)) scale(1);
    }
    100% {
      opacity: 0;
      transform: translate(calc(-50% + var(--emote-dx, 0px) * 1.4), calc(-50% - 28px)) scale(0.7);
    }
  }

  /* Speech bubble — anchored well above the sprite so it never overlaps
     the head (especially while a hat is on). */
  .site-pet__bubble {
    position: absolute;
    left: 22px; /* half the sprite width */
    bottom: calc(100% + 14px);
    transform: translate(-50%, 0) translateY(4px);
    padding: 6px 10px;
    border-radius: 10px;
    background: rgba(18, 18, 18, 0.82);
    color: #f3e9d6;
    font-family: var(--font-mono, "Source Code Pro", monospace);
    font-size: 11px;
    line-height: 1.2;
    letter-spacing: 0.01em;
    text-align: center;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition:
      opacity 180ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    box-shadow: 0 6px 14px -6px rgba(0, 0, 0, 0.4);
  }
  .site-pet__bubble[data-show] {
    opacity: 1;
    transform: translate(-50%, 0);
  }
  /*
    Bubble tail — a downward CSS triangle sitting flush below the bubble.
    Using borders instead of a rotated square means the tail never
    overlaps the bubble, so the translucent fill doesn't double up into
    a visible diamond through the bubble body.
  */
  .site-pet__bubble::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 100%;
    width: 0;
    height: 0;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: rgba(18, 18, 18, 0.82);
    border-bottom: 0;
  }

  [data-pet-guided] {
    outline: 2px solid rgba(218, 204, 157, 0.78) !important;
