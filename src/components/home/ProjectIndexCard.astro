---
/*
  Project index card — Figma spec (node 178:615 default / 179:639 expanded).
  Cream paper block with a small hole-punch + "No. NN" badge, hero image,
  title + tags, short description. On hover the title scales up, a hairline
  divider appears, and a ROLE / TEAM / TIMEFRAME grid slides in.
*/

import Tag from "../ui/Tag.astro";
import ProjectTileVisual from "./ProjectTileVisual.astro";

type Status = string;
type StatusProp = Status | Status[];

interface Props {
  title: string;
  slug?: string;
  number: number;
  role: string;
  team: string;
  shipped: string;
  status: StatusProp;
  sideProject?: boolean;
  /** One-line summary shown below the title. */
  description?: string;
  image?: string;
  accent?: string;
  imageHeight?: number;
  /** CSS background-position value, default "center". */
  imagePosition?: string;
  href?: string;
  /** Opens link in new tab + uses external cursor mode. */
  external?: boolean;
  /** Small idle rotation so a row of cards reads as a loose stack. */
  tilt?: number;
}

const {
  title,
  slug,
  number,
  role,
  team,
  shipped,
  status,
  sideProject = false,
  description,
  image,
  accent = "teal",
  imageHeight = 228,
  imagePosition = "center",
  href,
  external = false,
  tilt = 0,
} = Astro.props;

const Wrapper = href ? "a" : "article";
const num = String(number).padStart(2, "0");
---

<Wrapper
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  data-cursor={href ? (external ? "external" : "case-study") : undefined}
  style={`--card-tilt: ${tilt}deg; --card-accent: var(--color-${accent}, var(--color-teal));`}
  class:list={[
    "index-card group relative flex flex-col",
    href ? "cursor-none" : "cursor-default",
  ]}
>
  <div class="index-card__top">
    <span class="index-card__hole" aria-hidden="true"></span>
    <span class="index-card__num">No. {num}</span>
  </div>

  {slug ? (
    <div class="index-card__frame" style={`height: ${imageHeight}px;`}>
      <ProjectTileVisual slug={slug} title={title} accent={accent} />
    </div>
  ) : image ? (
    <div class="index-card__frame" style={`height: ${imageHeight}px;`}>
      <img
        src={image}
        alt=""
        loading="lazy"
        decoding="async"
        class="index-card__media"
        style={`object-position: ${imagePosition};`}
      />
    </div>
  ) : (
    <div class="index-card__frame index-card__frame--placeholder" style={`height: ${imageHeight}px;`}>
      <span class="index-card__placeholder-grid" aria-hidden="true"></span>
      <span class="index-card__placeholder-kicker">Project {num}</span>
      <span class="index-card__placeholder-title">{title}</span>
    </div>
  )}

  <div class="index-card__body">
    <div class="index-card__heading">
      <div class="index-card__header">
        <h3 class="index-card__title">{title}</h3>
        <div class="index-card__tags">
          {sideProject && <Tag>Side Project</Tag>}
          {Array.isArray(status) ? status.map((s) => <Tag>{s}</Tag>) : <Tag>{status}</Tag>}
        </div>
      </div>

      {description && (
        <p class="index-card__description">{description}</p>
      )}
    </div>

    <div class="index-card__details">
      <div class="index-card__details-inner">
        <span class="index-card__rule" aria-hidden="true"></span>
        <dl class="index-card__meta">
          <div class="index-card__meta-row">
            <dt>Role</dt>
            <dd>{role}</dd>
          </div>
          <div class="index-card__meta-row">
            <dt>Team</dt>
            <dd>{team}</dd>
          </div>
          <div class="index-card__meta-row">
            <dt>Timeframe</dt>
            <dd>{shipped}</dd>
          </div>
        </dl>
      </div>
    </div>

    <span class="index-card__action" aria-hidden="true">Open project</span>
  </div>
</Wrapper>

<style>
  /*
    Paper card. Background cream (--color-bg-light), soft warm drop shadow
    (0 0 4px #999079 from Figma), 16px corner radius, 16px padding. The
    inside stacks vertically with 8px gap between top row, image+body, and
    expands on hover to reveal the meta grid.
  */
  .index-card {
    position: relative;
    isolation: isolate;
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--card-accent) 12%, transparent), transparent 42%),
      var(--color-bg-light);
    color: var(--color-ink);
    border-radius: 10px;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transform: rotate(var(--card-tilt, 0deg));
    transform-origin: 50% 40%;
    box-shadow:
      inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 8%, transparent),
      0 0 4px 0 rgba(124, 86, 48, 0.34);
    transition:
      transform 320ms var(--ease-out-soft),
      box-shadow 480ms var(--ease-out-soft);
  }
  .index-card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    background:
      linear-gradient(90deg, transparent 0 18px, color-mix(in oklab, var(--card-accent) 24%, transparent) 18px 20px, transparent 20px),
      radial-gradient(circle at 88% 8%, color-mix(in oklab, var(--card-accent) 30%, transparent), transparent 28%);
    background-size: 38px 100%, auto;
    opacity: 0.32;
    transition: opacity 320ms var(--ease-out-soft);
  }
  .index-card::after {
    content: "";
    position: absolute;
    left: 8px;
    right: 8px;
    top: 29px;
    height: 3px;
    border-radius: 999px;
    background: var(--card-accent);
    opacity: 0.78;
    transform: scaleX(0.18);
    transform-origin: left center;
    transition: transform 360ms var(--ease-out-soft), opacity 260ms var(--ease-out-soft);
  }
  .index-card:hover {
    transform: rotate(0deg) translateY(-3px);
    box-shadow:
      inset 0 0 0 1px color-mix(in oklab, var(--card-accent) 28%, transparent),
      0 16px 28px -18px rgba(94, 55, 22, 0.48),
      0 0 4px 0 rgba(124, 86, 48, 0.34);
  }
  .index-card:hover::before {
    opacity: 0.54;
  }
  .index-card:hover::after {
    opacity: 1;
    transform: scaleX(1);
  }

  /* Top row — hole punch on the left, "No. NN" on the right. */
  .index-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }
  .index-card__hole {
    width: 13px;
    height: 13px;
    border-radius: 9999px;
    background: var(--color-bg);
    box-shadow:
      inset 0 1px 1.5px rgba(36, 36, 36, 0.35),
      inset 0 -0.5px 0.5px rgba(255, 255, 255, 0.4),
      0 0 0 1px color-mix(in oklab, var(--color-ink) 14%, transparent);
  }
  .index-card__num {
    display: inline-grid;
    place-items: center;
    min-width: 48px;
    height: 19px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--card-accent) 26%, var(--color-bg));
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 10%, transparent);
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  /* Media frame. */
  .index-card__frame {
    position: relative;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    box-shadow:
      inset 0 0 0 1px color-mix(in oklab, var(--color-ink) 8%, transparent),
      0 8px 18px -16px rgba(36, 36, 36, 0.52);
    transform: translateZ(0);
  }
  .index-card__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: translateZ(0);
    transition: transform 480ms var(--ease-out-soft);
  }
  .index-card__frame--placeholder {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 6px;
    padding: 16px;
    background:
      radial-gradient(circle at 78% 16%, color-mix(in oklab, var(--card-accent) 42%, white), transparent 30%),
      linear-gradient(135deg, color-mix(in oklab, var(--card-accent) 78%, #242424), #242424 74%);
    color: var(--color-ink-inverted);
  }
  .index-card__placeholder-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: linear-gradient(to bottom, black, transparent 72%);
    opacity: 0.85;
  }
  .index-card__placeholder-kicker,
  .index-card__placeholder-title {
    position: relative;
    z-index: 1;
  }
  .index-card__placeholder-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }
  .index-card__placeholder-title {
    max-width: 15ch;
    font-family: var(--font-display);
    font-size: 28px;
    line-height: 0.95;
  }
  .index-card:hover .index-card__media {
    transform: scale(1.03);
  }

  /* Body wrapper — single flex column with 12px gap between heading group
     and the hidden meta (shown on hover). */
  .index-card__body {
    display: flex;
    flex-direction: column;
    margin-top: 2px;
  }

  .index-card__heading {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .index-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }

  /* Title locked to a single size across default + expanded so the card
     doesn't pop when meta reveals on hover. */
  .index-card__title {
    flex: 1 1 auto;
    min-width: 0;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 15px;
    line-height: 1.08;
    color: var(--color-ink);
    margin: 0;
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .index-card__tags {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    max-width: 45%;
    justify-content: flex-end;
  }

  .index-card__description {
    margin: 0;
    font-family: var(--font-body);
    font-size: 10px;
    line-height: 1.25;
    color: #6b6553;
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  .index-card__action {
    margin-top: 5px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    width: max-content;
    font-family: var(--font-mono);
    font-size: 9px;
    line-height: 1;
    text-transform: uppercase;
    color: var(--color-ink);
    opacity: 0.58;
    transform: translateX(0);
    transition:
      opacity 240ms var(--ease-out-soft),
      transform 240ms var(--ease-out-soft);
  }
  .index-card__action::after {
    content: "";
    width: 18px;
    height: 1px;
    background: currentColor;
    transform-origin: left center;
    transition: transform 240ms var(--ease-out-soft);
  }
  .index-card:hover .index-card__action {
    opacity: 1;
    transform: translateX(3px);
  }
  .index-card:hover .index-card__action::after {
    transform: scaleX(1.4);
  }

  /*
    Expandable meta block — collapsed to 0 height at rest, reveals on hover.
    Grid with a single inner wrapper so the 0fr track actually collapses
    (two direct children would flow into an auto-sized second row).
  */
  .index-card__details {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 320ms var(--ease-out-soft);
  }
  .index-card__details-inner {
    min-height: 0;
    overflow: hidden;
  }
  .index-card:hover .index-card__details {
    grid-template-rows: 1fr;
  }

  /* Dashed divider — thin, low-contrast dots à la the Figma spec so it
     reads as a quiet separator, not a bold line. */
  .index-card__rule {
    display: block;
    width: 100%;
    height: 1px;
    margin-top: 5px;
    margin-bottom: 5px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='8' height='1'><line x1='0' y1='0.5' x2='3' y2='0.5' stroke='%23242424' stroke-opacity='0.22' stroke-width='1' stroke-linecap='round'/></svg>");
    background-repeat: repeat-x;
    background-position: left center;
    background-size: 8px 1px;
    opacity: 0;
    transition: opacity 200ms 80ms var(--ease-out-soft);
  }
  .index-card:hover .index-card__rule {
    opacity: 1;
  }

  .index-card__meta {
    margin: 0;
    padding-bottom: 2px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 260ms var(--ease-out-soft),
      transform 260ms var(--ease-out-soft);
  }
  .index-card:hover .index-card__meta {
    opacity: 1;
    transform: translateY(0);
  }

  /* Each row: mono label (width 90px) + body value, same grammar as the
     Figma expanded card. `display: contents` on the wrapper div would
     collapse too aggressively, so keep per-row grid columns. */
  .index-card__meta-row {
    display: grid;
    grid-template-columns: 64px 1fr;
    column-gap: 12px;
    font-size: 10px;
    /* line-height must leave room for descenders (g/y/p) — otherwise the
       parent's `overflow: hidden` clips the tail of the last row. */
    line-height: 1.25;
  }
  .index-card__meta dt {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-ink-dim);
  }
  .index-card__meta dd {
    margin: 0;
    font-family: var(--font-body);
    color: #6b6553;
  }

  @media (prefers-reduced-motion: reduce) {
    .index-card,
    .index-card__media,
    .index-card__title,
    .index-card__details,
    .index-card__rule,
    .index-card__meta {
      transition: none;
    }
    .index-card:hover {
      transform: rotate(0deg);
    }
    .index-card::before,
    .index-card::after,
    .index-card__action {
      transition: none;
    }
    .index-card:hover .index-card__media {
      transform: none;
    }
    /* Reduced motion: keep the archival details always visible so the
       info isn't hidden behind an interaction people can't trigger. */
    .index-card__details {
      grid-template-rows: 1fr;
    }
    .index-card__rule,
    .index-card__meta {
      opacity: 1;
      transform: none;
    }
  }
</style>
