---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import SitePet from "../components/site/SitePet.astro";
import { withBase } from "../lib/paths";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  bodyClass?: string;
  darkHtml?: boolean;
  showPet?: boolean;
  /** Override the canonical URL — pass a path (e.g. "/home") when the
   *  current page should consolidate SEO signals onto a different URL. */
  canonical?: string;
}

const {
  title = "Aishwarya's Portfolio",
  description = "Portfolio of Aishwarya.",
  image = "/og.png",
  bodyClass = "",
  darkHtml = false,
  showPet = true,
  canonical,
} = Astro.props;

const canonicalUrl = new URL(canonical ? withBase(canonical) : Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(withBase(image), Astro.site).href;
const iconUrl = withBase("/portfolio-logo.png");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Aishwarya's Portfolio" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/png" href={iconUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@300;400;500;600&display=swap"
    />
    <title>{title}</title>
    <ClientRouter />
    {darkHtml && <style set:html="html { background: var(--color-cosmos-2) !important; }" />}

    <style is:global>
      /*
        View Transitions — disable all default animations so page swaps
        are instant. Named groups (wallet-veil) can opt back in.
      */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation: none !important;
      }

      /* Wallet finale: the cream overlay on onboarding shares `wallet-veil`
         with a matching veil on home, so the cream fades out while home's
         content slides in under it. */
      ::view-transition-old(wallet-veil),
      ::view-transition-new(wallet-veil) {
        animation-duration: 720ms;
        animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
      }



      /* Named transition groups use no default animation either. */
      ::view-transition-old(sidebar),
      ::view-transition-new(sidebar) {
        animation: none !important;
      }
    </style>
  </head>
  <body class={bodyClass}>
    <slot />
    {showPet && <SitePet />}
  </body>
</html>
